# handlers/48_add_page_numbers.py
import os
import shutil
from lxml import etree
from utils import xml_utils

# Пространства имён
NS_REL = 'http://schemas.openxmlformats.org/officeDocument/2006/relationships'
NS_W = xml_utils.NAMESPACE

def tag(name):
    return f'{{{NS_W}}}{name}'

def create_footer_xml(footer_path):
    """Создаёт файл footer.xml с номером страницы по центру (Times New Roman 14pt)."""
    root = etree.Element(tag('ftr'), nsmap={'w': NS_W})
    # Абзац
    p = etree.SubElement(root, tag('p'))
    pPr = etree.SubElement(p, tag('pPr'))
    # Выравнивание по центру
    jc = etree.SubElement(pPr, tag('jc'))
    jc.set(tag('val'), 'center')
    # Свойства шрифта для всего абзаца
    rPr = etree.SubElement(pPr, tag('rPr'))
    rFonts = etree.SubElement(rPr, tag('rFonts'))
    rFonts.set(tag('ascii'), 'Times New Roman')
    rFonts.set(tag('hAnsi'), 'Times New Roman')
    rFonts.set(tag('cs'), 'Times New Roman')
    sz = etree.SubElement(rPr, tag('sz'))
    sz.set(tag('val'), '28')  # 14 pt
    szCs = etree.SubElement(rPr, tag('szCs'))
    szCs.set(tag('val'), '28')

    # Прогон с полем PAGE
    r = etree.SubElement(p, tag('r'))
    # Начало поля
    fldChar = etree.SubElement(r, tag('fldChar'))
    fldChar.set(tag('fldCharType'), 'begin')
    # Инструкция
    r2 = etree.SubElement(p, tag('r'))
    instrText = etree.SubElement(r2, tag('instrText'))
    instrText.set('xml:space', 'preserve')
    instrText.text = 'PAGE'
    # Разделитель
    r3 = etree.SubElement(p, tag('r'))
    fldChar2 = etree.SubElement(r3, tag('fldChar'))
    fldChar2.set(tag('fldCharType'), 'separate')
    # Текст-заполнитель
    r4 = etree.SubElement(p, tag('r'))
    t = etree.SubElement(r4, tag('t'))
    t.text = '1'
    # Конец поля
    r5 = etree.SubElement(p, tag('r'))
    fldChar3 = etree.SubElement(r5, tag('fldChar'))
    fldChar3.set(tag('fldCharType'), 'end')

    # Запись файла
    tree = etree.ElementTree(root)
    tree.write(footer_path, encoding='UTF-8', xml_declaration=True)

def update_document_rels(rels_path, footer_filename):
    """Добавляет отношение к footer.xml в document.xml.rels, возвращает id отношения."""
    if os.path.exists(rels_path):
        tree = etree.parse(rels_path)
        root = tree.getroot()
        # Ищем максимальный id
        max_id = 0
        for rel in root.findall(f'{{{NS_REL}}}Relationship'):
            rid = rel.get('Id')
            if rid and rid.startswith('rId'):
                try:
                    num = int(rid[3:])
                    if num > max_id:
                        max_id = num
                except:
                    pass
        new_id = f'rId{max_id + 1}'
    else:
        # Создаём новый корень
        root = etree.Element('Relationships', xmlns=NS_REL)
        new_id = 'rId1'

    # Добавляем отношение
    rel_elem = etree.SubElement(root, 'Relationship')
    rel_elem.set('Id', new_id)
    rel_elem.set('Type', 'http://schemas.openxmlformats.org/officeDocument/2006/relationships/footer')
    rel_elem.set('Target', f'footer.xml')  # относительно word/

    tree = etree.ElementTree(root)
    tree.write(rels_path, encoding='UTF-8', xml_declaration=True)
    return new_id

def process(doc_root, styles_root=None, log=print, temp_dir=None):
    """
    Добавляет нижний колонтитул с номером страницы по центру (Times New Roman 14).
    Удаляет старые колонтитулы, если они есть.
    """
    log(">>> Добавление нумерации страниц (нижний колонтитул)")

    if temp_dir is None:
        log("  Ошибка: не указана временная папка (temp_dir)")
        return

    word_dir = os.path.join(temp_dir, 'word')
    if not os.path.exists(word_dir):
        log("  Папка word не найдена")
        return

    # 1. Удаляем старые файлы footer*.xml (если есть)
    for fname in os.listdir(word_dir):
        if fname.startswith('footer') and fname.endswith('.xml'):
            os.remove(os.path.join(word_dir, fname))
            log(f"  Удалён старый файл: {fname}")

    # 2. Создаём новый footer.xml
    footer_path = os.path.join(word_dir, 'footer.xml')
    create_footer_xml(footer_path)
    log("  Создан footer.xml")

    # 3. Обновляем document.xml.rels
    rels_path = os.path.join(word_dir, '_rels', 'document.xml.rels')
    os.makedirs(os.path.dirname(rels_path), exist_ok=True)
    rel_id = update_document_rels(rels_path, 'footer.xml')
    log(f"  Добавлено отношение с id={rel_id}")

    # 4. Обновляем document.xml: добавляем ссылку на колонтитул в каждую секцию
    doc_path = os.path.join(word_dir, 'document.xml')
    if not os.path.exists(doc_path):
        log("  document.xml не найден")
        return

    doc_tree = etree.parse(doc_path)
    doc_root_local = doc_tree.getroot()

    # Находим все элементы sectPr
    sectPr_list = doc_root_local.findall(f'.//{tag("sectPr")}')
    if not sectPr_list:
        # Если нет sectPr, создаём в конце body
        body = doc_root_local.find(tag('body'))
        if body is not None:
            sectPr = etree.SubElement(body, tag('sectPr'))
            sectPr_list = [sectPr]

    for sectPr in sectPr_list:
        # Удаляем старые ссылки на нижние колонтитулы
        for footerRef in sectPr.findall(tag('footerReference')):
            sectPr.remove(footerRef)
        # Добавляем новую ссылку
        footer_ref = etree.SubElement(sectPr, tag('footerReference'))
        footer_ref.set(tag('type'), 'default')
        footer_ref.set('r:id', rel_id)

    # Сохраняем document.xml
    doc_tree.write(doc_path, encoding='UTF-8', xml_declaration=True)
    log("  document.xml обновлён (добавлены ссылки на footer)")

    log("<<< Добавление нумерации страниц завершено")
Пояснения
Обработчик ожидает параметр temp_dir (путь к распакованной папке). В main.py после распаковки можно передать его в обработчик. Для этого нужно модифицировать main.py, чтобы при вызове обработчика передавать temp_dir. Предлагаю в цикле вызова обработчиков добавить передачу temp_dir как аргумента, если обработчик его принимает. Либо создать отдельную функцию, которая будет вызываться после всех обработчиков.

В main.py после цикла обработчиков можно вызвать этот обработчик отдельно, передав temp_dir. Например:

python
# После всех обработчиков
from handlers import _48_add_page_numbers
_48_add_page_numbers.process(doc_root, styles_root, log=print, temp_dir=temp_dir)
Но поскольку у нас динамическая загрузка, нужно либо сделать исключение для этого обработчика, либо модифицировать каждый обработчик, чтобы он принимал temp_dir (сейчас они его не используют). Проще добавить в main.py после основного цикла вызов этого обработчика отдельно.

Что делает код
Удаляет все существующие файлы footer*.xml в папке word.

Создаёт новый footer.xml с полем PAGE, выровненным по центру, шрифт Times New Roman 14pt.

Добавляет отношение к этому файлу в document.xml.rels.

Для каждой секции (<w:sectPr>) удаляет старые ссылки на нижние колонтитулы и добавляет новую ссылку с созданным id.

Примечания
Обработчик должен вызываться после всех изменений в документе, но до упаковки. Лучше всего добавить его вызов в main.py после цикла обработчиков, но до сохранения document.xml? Сейчас мы сохраняем после цикла. Можно добавить вызов после сохранения, но перед упаковкой, и передать ему temp_dir. Нужно убедиться, что doc_root синхронизирован с файлом, но поскольку мы работаем напрямую с файловой системой, это не проблема. Просто после вызова обработчика не нужно заново сохранять document.xml, потому что он сам его сохраняет.

В текущем main.py после цикла обработчиков мы сохраняем tree и styles_tree. Затем идёт копирование XML, упаковка. В этом месте можно вставить вызов 48_add_page_numbers.process(doc_root, styles_root, log=print, temp_dir=temp_dir). Но тогда doc_root может быть не синхронизирован с файлом после изменений в колонтитулах? Обработчик работает напрямую с файлом, перечитывая его. Это нормально. Главное, чтобы после его работы мы не сохраняли doc_root повторно (иначе потеряем изменения). Поэтому лучше вызвать этот обработчик после сохранения tree и styles_tree, но перед упаковкой. И не сохранять doc_root после него.

Таким образом, модифицируем main.py:

python
# ... после сохранения tree и styles_tree
# Сохраняем изменения (уже есть)
tree.write(doc_path, encoding='UTF-8', xml_declaration=True)
if styles_root is not None:
    styles_tree.write(styles_path, encoding='UTF-8', xml_declaration=True)

# Вызываем обработчик нумерации страниц
try:
    from handlers import _48_add_page_numbers
    _48_add_page_numbers.process(doc_root, styles_root, log=print, temp_dir=temp_dir)
except ImportError:
    print("  Обработчик 48_add_page_numbers не найден, пропускаем")
except Exception as e:
    print(f"  Ошибка при добавлении нумерации страниц: {e}")

# Отладочная копия и упаковка...
Обратите внимание, что имя файла может быть 48_add_page_numbers.py, а импорт _48_add_page_numbers из-за недопустимости имени, начинающегося с цифры. Поэтому в папке handlers файл должен называться 48_add_page_numbers.py, а импортировать его можно как handlers._48_add_page_numbers.

скинь полны маин
Мы подготовили полный main.py с учетом всех обсуждений и добавлением вызова обработчика нумерации страниц. Однако перед этим нужно убедиться, что в main.py правильно передается temp_dir. В текущей версии main.py переменная temp_dir определена и используется в docx_io.cleanup_temp(temp_dir). Мы добавим вызов обработчика 48_add_page_numbers после сохранения изменений, но до упаковки. Также учтем, что импорт модуля с цифрой в начале имени требует особого синтаксиса.

Приведем полный код main.py с учетом всех последних изменений: функция принудительного завершения Word, запуск preprocessor, загрузка обработчиков, обработка XML, добавление нумерации страниц, предложение открыть файл.

Вот финальный вариант:

python
import os
import sys
import time
import shutil
import subprocess
import importlib
import pkgutil
from tkinter import Tk, filedialog, messagebox
from lxml import etree

from utils import docx_io, xml_utils
import handlers

def kill_word_processes():
    """Принудительно завершает все процессы Microsoft Word."""
    try:
        subprocess.run(['taskkill', '/f', '/im', 'winword.exe'], 
                       stdout=subprocess.DEVNULL, 
                       stderr=subprocess.DEVNULL)
        print("Все процессы Word завершены.")
    except Exception as e:
        print(f"Ошибка при завершении Word: {e}")

def run_preprocessor(input_path):
    """
    Запускает preprocessor.py как отдельный процесс.
    Возвращает путь к обработанному файлу (с суффиксом _normalized.docx).
    """
    preprocessor_path = os.path.join(os.path.dirname(__file__), 'preprocessor.py')
    if not os.path.exists(preprocessor_path):
        raise FileNotFoundError("preprocessor.py не найден в папке проекта")

    base, ext = os.path.splitext(input_path)
    output_path = f"{base}_normalized{ext}"

    print(f"Запуск preprocessor.py для преобразования нумерации...")
    result = subprocess.run(
        [sys.executable, preprocessor_path, input_path, output_path],
        capture_output=True,
        text=True
    )
    if result.returncode != 0:
        print("Ошибка при выполнении preprocessor.py:")
        print(result.stderr)
        raise RuntimeError("Препроцессор завершился с ошибкой")

    print("Препроцессор выполнен успешно.")
    print(result.stdout)
    return output_path

def load_handlers():
    """Загружает все обработчики из папки handlers, у которых есть функция process."""
    handlers_list = []
    for finder, name, ispkg in pkgutil.iter_modules(handlers.__path__):
        module = importlib.import_module(f'handlers.{name}')
        if hasattr(module, 'process'):
            handlers_list.append(module.process)
    # Сортируем по имени файла (для предсказуемого порядка)
    handlers_list.sort(key=lambda h: h.__module__)
    return handlers_list

def main():
    root = Tk()
    root.withdraw()

    input_path = filedialog.askopenfilename(
        title="Выберите DOCX-файл для обработки",
        filetypes=[("Word документы", "*.docx"), ("Все файлы", "*.*")]
    )
    if not input_path:
        print("Файл не выбран. Выход.")
        return

    print(f"Исходный файл: {input_path}")

    # Принудительно закрываем Word перед работой
    kill_word_processes()

    # Шаг 1: запускаем COM-препроцессор для конвертации нумерации
    try:
        normalized_path = run_preprocessor(input_path)
        print(f"Файл после препроцессора: {normalized_path}")
        time.sleep(1)  # даём Word время освободить файл
    except Exception as e:
        print(f"Ошибка на этапе препроцессора: {e}")
        messagebox.showerror("Ошибка", f"Препроцессор не сработал:\n{e}")
        return

    # Шаг 2: работаем с полученным файлом через XML-парсер
    temp_copy = docx_io.copy_docx(normalized_path)
    print(f"Копия для XML-обработки: {temp_copy}")

    temp_dir = docx_io.extract_docx(temp_copy)
    print(f"Распаковано во временную папку: {temp_dir}")

    result_path = None  # сохраним путь к итоговому файлу

    try:
        doc_path = os.path.join(temp_dir, 'word', 'document.xml')
        tree = etree.parse(doc_path)
        doc_root = tree.getroot()

        styles_path = os.path.join(temp_dir, 'word', 'styles.xml')
        styles_root = None
        if os.path.exists(styles_path):
            styles_tree = etree.parse(styles_path)
            styles_root = styles_tree.getroot()

        handlers_list = load_handlers()
        print(f"Загружено XML-обработчиков: {len(handlers_list)}")

        for handler in handlers_list:
            print(f"\n>>> Запуск {handler.__module__}")
            # Передаём temp_dir, если функция принимает такой аргумент
            # (для совместимости со старыми обработчиками)
            try:
                handler(doc_root, styles_root, log=print, temp_dir=temp_dir)
            except TypeError:
                # Если обработчик не принимает temp_dir, вызываем без него
                handler(doc_root, styles_root, log=print)
            print(f"<<< Завершён {handler.__module__}")

        # Сохраняем изменения
        tree.write(doc_path, encoding='UTF-8', xml_declaration=True)
        if styles_root is not None:
            styles_tree.write(styles_path, encoding='UTF-8', xml_declaration=True)

        # Отладочная копия XML
        debug_xml_path = os.path.join(
            os.path.dirname(temp_copy),
            os.path.basename(temp_copy).replace('.docx', '_document.xml')
        )
        shutil.copy2(doc_path, debug_xml_path)
        print(f"Отладочная копия XML сохранена: {debug_xml_path}")

        # Дополнительно вызываем обработчик нумерации страниц (он уже мог быть в списке,
        # но если нет – можно вызвать явно)
        try:
            from handlers import _48_add_page_numbers
            _48_add_page_numbers.process(doc_root, styles_root, log=print, temp_dir=temp_dir)
        except ImportError:
            print("  Обработчик 48_add_page_numbers не найден, пропускаем")
        except Exception as e:
            print(f"  Ошибка при добавлении нумерации страниц: {e}")

        # Упаковываем обратно в DOCX
        docx_io.pack_docx(temp_dir, temp_copy)
        result_path = temp_copy
        print(f"\nГотово! Результат сохранён в: {temp_copy}")
        messagebox.showinfo("Готово", f"Файл успешно обработан:\n{temp_copy}")

    except Exception as e:
        print(f"!!! Критическая ошибка при XML-обработке: {e}")
        messagebox.showerror("Ошибка", str(e))
    finally:
        docx_io.cleanup_temp(temp_dir)
        print("Временные файлы XML-этапа удалены.")

    # Предложение открыть файл, если обработка прошла успешно
    if result_path and os.path.exists(result_path):
        if messagebox.askyesno("Открыть файл", "Открыть полученный файл?"):
            try:
                os.startfile(result_path)
            except Exception as e:
                print(f"Не удалось открыть файл: {e}")
                messagebox.showerror("Ошибка", f"Не удалось открыть файл:\n{e}")

if __name__ == "__main__":
    main()
