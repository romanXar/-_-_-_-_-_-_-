from utils import xml_utils
from lxml import etree

def is_structural_element(text):
    text_upper = text.strip().upper()
    if text_upper in ("РЕФЕРАТ", "СОДЕРЖАНИЕ", "ВВЕДЕНИЕ", "ЗАКЛЮЧЕНИЕ", 
