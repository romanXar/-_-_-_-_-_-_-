# handlers/44_format_tables.py
from lxml import etree
from utils import xml_utils

# Константы для форматирования таблиц по СТУ
TABLE_FONT_SIZE = "24"       # 12 pt (в half-points)
TABLE_FONT = "Times New Roman"
TABLE_LINE_SPACING = "240"   # одинарный для 12 pt
TABLE_INDENT = "0"           # отступы отсутствуют

def get_cell_bottom_double_border(cell):
    """Возвращает элемент w:bottom с двойной линией из ячейки, если есть."""
    tcPr = cell.find(xml_utils.tag('tcPr'))
    if tcPr is None:
        return None
    borders = tcPr.find(xml_utils.tag('tcBorders'))
    if borders is None:
        return None
    bottom = borders.find(xml_utils.tag('bottom'))
    if bottom is not None and bottom.get(xml_utils.tag('val')) == 'double':
        return bottom
    return None

def has_double_border_row(row):
    """Проверяет, есть ли в строке ячейка с двойной нижней границей."""
    for cell in row.findall(xml_utils.tag('tc')):
        if get_cell_bottom_double_border(cell) is not None:
            return True
    return False

def copy_double_border_to_row_cells(row, sample_cell):
    """
    Копирует двойную нижнюю границу из sample_cell во все остальные ячейки строки.
    Сохраняет все атрибуты (толщину, цвет и т.д.).
    """
    sample_border = get_cell_bottom_double_border(sample_cell)
    if sample_border is None:
        return

    for cell in row.findall(xml_utils.tag('tc')):
        if cell == sample_cell:
            continue
        tcPr = cell.find(xml_utils.tag('tcPr'))
        if tcPr is None:
            tcPr = etree.SubElement(cell, xml_utils.tag('tcPr'))
        borders = tcPr.find(xml_utils.tag('tcBorders'))
        if borders is None:
            borders = etree.SubElement(tcPr, xml_utils.tag('tcBorders'))
        bottom = borders.find(xml_utils.tag('bottom'))
        if bottom is None:
            bottom = etree.SubElement(borders, xml_utils.tag('bottom'))
        # Копируем все атрибуты
        for key, value in sample_border.attrib.items():
            bottom.set(key, value)

def reset_paragraph_formatting(p, bold=False, align='left'):
    """
    Полностью переопределяет форматирование абзаца:
    - удаляет ссылку на стиль (w:pStyle)
    - удаляет локальное форматирование прогонов (w:rPr)
    - устанавливает шрифт Times New Roman 12 pt, одинарный интервал, отступы 0
    - применяет жирность (если bold=True) и выравнивание
    """
    # 1. Работа с pPr
    pPr = p.find(xml_utils.tag('pPr'))
    if pPr is None:
        pPr = etree.SubElement(p, xml_utils.tag('pPr'))
    else:
        # Удаляем w:pStyle, если есть
        pStyle = pPr.find(xml_utils.tag('pStyle'))
        if pStyle is not None:
            pPr.remove(pStyle)
        # Удаляем старый w:rPr в pPr, чтобы не мешал
        old_rPr = pPr.find(xml_utils.tag('rPr'))
        if old_rPr is not None:
            pPr.remove(old_rPr)
        # Удаляем старые отступы и интервалы (они будут заданы заново)
        ind = pPr.find(xml_utils.tag('ind'))
        if ind is not None:
            pPr.remove(ind)
        spacing = pPr.find(xml_utils.tag('spacing'))
        if spacing is not None:
            pPr.remove(spacing)
        jc = pPr.find(xml_utils.tag('jc'))
        if jc is not None:
            pPr.remove(jc)

    # Создаём новый w:rPr в pPr
    rPr = etree.SubElement(pPr, xml_utils.tag('rPr'))

    # Шрифт
    rFonts = etree.SubElement(rPr, xml_utils.tag('rFonts'))
    rFonts.set(xml_utils.tag('ascii'), TABLE_FONT)
    rFonts.set(xml_utils.tag('hAnsi'), TABLE_FONT)
    rFonts.set(xml_utils.tag('cs'), TABLE_FONT)

    # Размер
    sz = etree.SubElement(rPr, xml_utils.tag('sz'))
    sz.set(xml_utils.tag('val'), TABLE_FONT_SIZE)
    szCs = etree.SubElement(rPr, xml_utils.tag('szCs'))
    szCs.set(xml_utils.tag('val'), TABLE_FONT_SIZE)

    if bold:
        b = etree.SubElement(rPr, xml_utils.tag('b'))

    # Отступы
    ind = etree.SubElement(pPr, xml_utils.tag('ind'))
    ind.set(xml_utils.tag('firstLine'), TABLE_INDENT)
    ind.set(xml_utils.tag('left'), TABLE_INDENT)

    # Интервал (одинарный)
    spacing = etree.SubElement(pPr, xml_utils.tag('spacing'))
    spacing.set(xml_utils.tag('line'), TABLE_LINE_SPACING)
    spacing.set(xml_utils.tag('lineRule'), 'auto')

    # Выравнивание
    jc = etree.SubElement(pPr, xml_utils.tag('jc'))
    jc.set(xml_utils.tag('val'), align)

    # 2. Очищаем локальное форматирование прогонов (удаляем w:rPr)
    for r in p.findall(xml_utils.tag('r')):
        rPr = r.find(xml_utils.tag('rPr'))
        if rPr is not None:
            r.remove(rPr)

def format_cell_paragraphs(cell, bold=False, align='left'):
    """Применяет форматирование ко всем абзацам в ячейке."""
    for p in cell.findall(xml_utils.tag('p')):
        reset_paragraph_formatting(p, bold, align)

def process(doc_root, styles_root=None, log=print):
    log(">>> Форматирование таблиц (по двойной линии, с полным переопределением)")

    tables = doc_root.findall(f'.//{xml_utils.tag("tbl")}')
    log(f"Найдено таблиц: {len(tables)}")

    formatted_tables = 0

    for tbl_idx, table in enumerate(tables, 1):
        rows = table.findall(f'.//{xml_utils.tag("tr")}')
        if not rows:
            continue

        # Ищем строку с двойной границей
        marker_row_index = None
        marker_cell = None
        for i, row in enumerate(rows):
            for cell in row.findall(xml_utils.tag('tc')):
                if get_cell_bottom_double_border(cell) is not None:
                    marker_row_index = i
                    marker_cell = cell
                    break
            if marker_row_index is not None:
                break

        if marker_row_index is None:
            log(f"  Таблица {tbl_idx}: не найдена строка с двойной линией, пропускаем")
            continue

        log(f"  Таблица {tbl_idx}: строка-маркер #{marker_row_index+1}")

        # Форматируем строки до и включая маркер как заголовок (жирный, по центру)
        for i in range(marker_row_index + 1):
            row = rows[i]
            for cell in row.findall(xml_utils.tag('tc')):
                format_cell_paragraphs(cell, bold=True, align='center')

        # Форматируем строки после маркера как тело (обычный, по левому краю)
        for i in range(marker_row_index + 1, len(rows)):
            row = rows[i]
            for cell in row.findall(xml_utils.tag('tc')):
                format_cell_paragraphs(cell, bold=False, align='left')

        # Копируем двойную линию на все ячейки строки-маркера
        copy_double_border_to_row_cells(rows[marker_row_index], marker_cell)

        formatted_tables += 1
        log(f"  Таблица {tbl_idx}: обработана")

    log(f"Обработано таблиц: {formatted_tables}")
    log("<<< Форматирование таблиц завершено")
Что изменилось по сравнению с предыдущей версией
Функция reset_paragraph_formatting теперь полностью переопределяет все параметры абзаца: удаляет w:pStyle, старые w:rPr, отступы, интервалы и выравнивание, а затем устанавливает нужные значения заново.

Шрифт явно задаётся как Times New Roman, размер 12 pt, одинарный интервал, отступы 0.

Для заголовков дополнительно включается жирность и выравнивание по центру, для тела — обычный шрифт и выравнивание по левому краю.

