Модифицированный обработчик 41_insert_empty_lines.py (полный код)
python
# handlers/41_insert_empty_lines.py
import re
from lxml import etree
from utils import xml_utils

MATH_NS = 'http://schemas.openxmlformats.org/officeDocument/2006/math'
NSMAP = {'w': xml_utils.NAMESPACE, 'm': MATH_NS}

def is_structural_heading(text):
    """Структурный заголовок (капсом, не цифры)."""
    if len(text) < 3:
        return False
    return text.isupper() and not text.isdigit()

def is_heading(text):
    """Нумерованный заголовок (начинается с цифр)."""
    return re.match(r'^\d+(\.\d+)*\s', text) is not None

def is_figure_caption(text):
    """Подпись рисунка."""
    return text.lower().startswith('рисунок')

def is_math_paragraph(p):
    """Проверка на формулу."""
    if p.find('.//m:oMath', namespaces=NSMAP) is not None:
        return True
    if p.find('.//m:oMathPara', namespaces=NSMAP) is not None:
        return True
    return False

def is_empty_paragraph(p):
    """Проверяет, является ли абзац пустым (нет текста, нет рисунков, нет таблиц)."""
    text = xml_utils.get_paragraph_text(p).strip()
    if text:
        return False
    if xml_utils.has_drawing(p):
        return False
    if xml_utils.has_table(p):
        return False
    return True

def create_empty_paragraph(with_keepNext=False):
    """
    Создаёт новый пустой абзац со стилем Normal и нулевыми отступами.
    Если with_keepNext=True, добавляет тег <w:keepNext/>,
    чтобы абзац не отрывался от следующего.
    """
    new_p = etree.Element(xml_utils.tag('p'))
    pPr = etree.SubElement(new_p, xml_utils.tag('pPr'))
    pStyle = etree.SubElement(pPr, xml_utils.tag('pStyle'))
    pStyle.set(xml_utils.tag('val'), "Normal")
    ind = etree.SubElement(pPr, xml_utils.tag('ind'))
    ind.set(xml_utils.tag('firstLine'), "0")
    ind.set(xml_utils.tag('left'), "0")

    if with_keepNext:
        # Добавляем привязку к следующему абзацу
        etree.SubElement(pPr, xml_utils.tag('keepNext'))

    r = etree.SubElement(new_p, xml_utils.tag('r'))
    t = etree.SubElement(r, xml_utils.tag('t'))
    t.text = ""
    return new_p

def process(doc_root, styles_root=None, log=print):
    log(">>> Вставка пустых строк вокруг заголовков, подписей и формул")

    paragraphs = xml_utils.find_all_paragraphs(doc_root)
    title_end = xml_utils.find_title_end_index(paragraphs)
    if title_end > 0:
        log(f"Титульник заканчивается на абзаце #{title_end}, обрабатываем с #{title_end+1}")
    else:
        log("Титульник не найден, обрабатываем всё")
        title_end = 0

    # Собираем индексы абзацев, которые нужно обработать (вне титульника и таблиц)
    target_indices = []
    for idx, p in enumerate(paragraphs, 1):
        if idx <= title_end:
            continue
        if xml_utils.is_inside_table(p):
            continue
        target_indices.append(idx)

    # Для каждого целевого абзаца определим его тип
    types = {}
    for idx in target_indices:
        p = paragraphs[idx-1]
        text = xml_utils.get_paragraph_text(p).strip()
        if is_structural_heading(text):
            types[idx] = 'struct_heading'
        elif is_heading(text):
            types[idx] = 'num_heading'
        elif is_figure_caption(text):
            types[idx] = 'caption'
        elif is_math_paragraph(p):
            types[idx] = 'formula'
        else:
            types[idx] = 'other'

    # Собираем действия (где вставить пустые абзацы) в виде списка (индекс, 'before'/'after')
    actions = []

    # Проходим по целевым абзацам в порядке возрастания
    for idx in target_indices:
        t = types[idx]

        # Проверка перед
        if t in ('struct_heading', 'num_heading', 'formula'):
            prev_idx = idx - 1
            if prev_idx >= 1 and prev_idx in types:
                prev_type = types[prev_idx]
                if prev_type in ('struct_heading', 'num_heading'):
                    pass
                else:
                    actions.append((idx, 'before'))
            elif prev_idx >= 1:
                prev_p = paragraphs[prev_idx-1]
                if not is_empty_paragraph(prev_p):
                    actions.append((idx, 'before'))
            else:
                pass

        # Проверка после
        if t in ('struct_heading', 'num_heading', 'caption', 'formula'):
            next_idx = idx + 1
            if next_idx <= len(paragraphs) and next_idx in types:
                next_type = types[next_idx]
                if t == 'caption' and next_type == 'caption':
                    pass
                elif t in ('struct_heading', 'num_heading') and next_type in ('struct_heading', 'num_heading'):
                    pass
                elif t == 'formula' and next_type == 'formula':
                    pass
                else:
                    actions.append((idx, 'after'))
            elif next_idx <= len(paragraphs):
                next_p = paragraphs[next_idx-1]
                if not is_empty_paragraph(next_p):
                    actions.append((idx, 'after'))
            else:
                pass

    # Теперь нужно вставить пустые абзацы, двигаясь с конца.
    actions.sort(key=lambda x: (x[0], 0 if x[1]=='after' else 1), reverse=True)

    inserted = 0
    for idx, where in actions:
        p = paragraphs[idx-1]
        parent = p.getparent()

        # Определяем, нужен ли keepNext для вставляемого абзаца
        # Для вставки после заголовков, подписей и формул ставим keepNext,
        # чтобы пустая строка прилипла к следующему тексту.
        need_keep = (where == 'after' and types[idx] in ('struct_heading', 'num_heading', 'caption', 'formula'))

        new_p = create_empty_paragraph(with_keepNext=need_keep)

        if where == 'after':
            parent.insert(parent.index(p) + 1, new_p)
        else:  # before
            parent.insert(parent.index(p), new_p)
        inserted += 1

    log(f"  Вставлено пустых абзацев: {inserted}")
    log("<<< Вставка пустых строк завершена")
Что изменилось
Функция create_empty_paragraph получила необязательный параметр with_keepNext. Если он True, в свойства абзаца добавляется тег <w:keepNext/>.

При формировании списка действий actions мы запоминаем тип абзаца (types), чтобы потом решить, нужен ли keepNext.

При вставке пустого абзаца после заголовков, подписей и формул (need_keep = True) создаём абзац с keepNext. Это гарантирует, что пустая строка «прилипнет» к следующему текстовому абзацу.

При вставке перед заголовками keepNext не нужен (там заголовок сам привязан к следующему за ним).

Зачем это нужно
Заголовки уже имеют <w:keepNext/> (добавлено в 40_final_formatting.py).

Теперь пустые строки после них тоже имеют keepNext.

В результате образуется цепочка: Заголовок → (keepNext) → Пустая строка → (keepNext) → Текст.

Если места на странице не хватает, все три элемента перейдут на следующую страницу вместе, и заголовок никогда не останется один внизу.

Примечание
