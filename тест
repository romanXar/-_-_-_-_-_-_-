# handlers/43_generate_toc.py
import re
from lxml import etree
from utils import xml_utils

# Копируем функции определения заголовков из 40_final_formatting для согласованности
def is_structural_heading(text):
    """Структурный заголовок (капсом, не цифры)."""
    if len(text) < 3:
        return False
    return text.isupper() and not text.isdigit()

def is_heading(text):
    """Нумерованный заголовок (начинается с цифр)."""
    return re.match(r'^\d+(\.\d+)*\s', text) is not None

def create_toc_paragraph():
    """
    Создаёт абзац с полем TOC (оглавление) с инструкцией TOC \o "1-3" \h \z \u.
    Возвращает элемент w:p.
    """
    # Создаём корневой элемент абзаца
    p = etree.Element(xml_utils.tag('p'))

    # Свойства абзаца (можно добавить стиль Normal)
    pPr = etree.SubElement(p, xml_utils.tag('pPr'))
    pStyle = etree.SubElement(pPr, xml_utils.tag('pStyle'))
    pStyle.set(xml_utils.tag('val'), "Normal")

    # Начало поля
    r1 = etree.SubElement(p, xml_utils.tag('r'))
    fldChar1 = etree.SubElement(r1, xml_utils.tag('fldChar'))
    fldChar1.set(xml_utils.tag('fldCharType'), "begin")

    # Инструкция TOC
    r2 = etree.SubElement(p, xml_utils.tag('r'))
    instrText = etree.SubElement(r2, xml_utils.tag('instrText'))
    instrText.set(xml_utils.NAMESPACE, "preserve")  # xml:space="preserve"
    instrText.text = r'TOC \o "1-3" \h \z \u'

    # Разделитель (separate)
    r3 = etree.SubElement(p, xml_utils.tag('r'))
    fldChar2 = etree.SubElement(r3, xml_utils.tag('fldChar'))
    fldChar2.set(xml_utils.tag('fldCharType'), "separate")

    # Текст-заполнитель (Word заменит его реальным оглавлением)
    r4 = etree.SubElement(p, xml_utils.tag('r'))
    t = etree.SubElement(r4, xml_utils.tag('t'))
    t.text = "Оглавление"

    # Конец поля
    r5 = etree.SubElement(p, xml_utils.tag('r'))
    fldChar3 = etree.SubElement(r5, xml_utils.tag('fldChar'))
    fldChar3.set(xml_utils.tag('fldCharType'), "end")

    return p

def process(doc_root, styles_root=None, log=print):
    """
    Ищет абзац с текстом «СОДЕРЖАНИЕ» (заголовок раздела оглавления).
    Если находит, удаляет всё содержимое между этим заголовком и следующим
    заголовком (структурным или нумерованным) и вставляет поле TOC сразу после
    заголовка «СОДЕРЖАНИЕ».
    """
    log(">>> Генерация оглавления (TOC)")

    paragraphs = xml_utils.find_all_paragraphs(doc_root)

    # Находим индекс абзаца с заголовком «СОДЕРЖАНИЕ»
    toc_title_idx = None
    for i, p in enumerate(paragraphs):
        text = xml_utils.get_paragraph_text(p).strip()
        # Сравниваем без учёта регистра и возможных лишних пробелов
        if text.upper() == "СОДЕРЖАНИЕ":
            toc_title_idx = i
            break

    if toc_title_idx is None:
        log("  Заголовок «СОДЕРЖАНИЕ» не найден, генерация TOC пропущена.")
        log("<<< Генерация оглавления завершена (без изменений)")
        return

    log(f"  Заголовок «СОДЕРЖАНИЕ» найден в абзаце #{toc_title_idx+1}")

    # Определяем конец раздела оглавления – следующий заголовок (структурный или нумерованный)
    end_idx = None
    for i in range(toc_title_idx + 1, len(paragraphs)):
        p = paragraphs[i]
        text = xml_utils.get_paragraph_text(p).strip()
        # Проверяем, является ли абзац заголовком (пропускаем пустые, если они есть)
        if text and (is_structural_heading(text) or is_heading(text)):
            end_idx = i
            break

    if end_idx is None:
        # Если следующего заголовка нет, удаляем все абзацы до конца документа
        end_idx = len(paragraphs)
        log(f"  Следующий заголовок не найден, будет удалено до конца документа.")
    else:
        log(f"  Следующий заголовок найден в абзаце #{end_idx+1}")

    # Удаляем все абзацы от toc_title_idx+1 до end_idx-1 включительно
    # Удаляем с конца, чтобы не сбивать индексы
    removed = 0
    for i in range(end_idx - 1, toc_title_idx, -1):
        p = paragraphs[i]
        parent = p.getparent()
        parent.remove(p)
        removed += 1

    log(f"  Удалено абзацев старого оглавления: {removed}")

    # Вставляем новый абзац с полем TOC сразу после заголовка «СОДЕРЖАНИЕ»
    toc_paragraph = create_toc_paragraph()
    title_paragraph = paragraphs[toc_title_idx]
    parent = title_paragraph.getparent()
    parent.insert(parent.index(title_paragraph) + 1, toc_paragraph)

    log("  Абзац с полем TOC вставлен.")

    # Для удобства можно добавить пустой абзац после TOC (по желанию)
    empty_p = etree.Element(xml_utils.tag('p'))
    pPr = etree.SubElement(empty_p, xml_utils.tag('pPr'))
    pStyle = etree.SubElement(pPr, xml_utils.tag('pStyle'))
    pStyle.set(xml_utils.tag('val'), "Normal")
    r = etree.SubElement(empty_p, xml_utils.tag('r'))
    t = etree.SubElement(r, xml_utils.tag('t'))
    t.text = ""
    parent.insert(parent.index(toc_paragraph) + 1, empty_p)
    log("  Добавлен пустой абзац после TOC для отступа.")

    log("<<< Генерация оглавления завершена")
Пояснения:

Поиск заголовка – ищем абзац, текст которого после обрезки пробелов и приведения к верхнему регистру равен "СОДЕРЖАНИЕ". Это покрывает случаи, когда слово написано капсом или с маленькой буквы (если потребуется регистронезависимость, можно просто сравнивать text.upper()).

Определение границ – после найденного заголовка ищем следующий абзац, который является структурным (капсом, не цифры) или нумерованным заголовком (начинается с цифр). Используем те же функции, что и в 40_final_formatting.py, чтобы классификация была единообразной.

Удаление старого оглавления – удаляются все абзацы, находящиеся между заголовком «СОДЕРЖАНИЕ» и следующим заголовком (или до конца документа, если следующего заголовка нет). Удаление выполняется в обратном порядке, чтобы не нарушить индексацию.

Вставка поля TOC – создаётся новый абзац с полем TOC (инструкция TOC \o "1-3" \h \z \u). Структура поля соответствует стандартному WordprocessingML: begin, instrText, separate, placeholder text, end. Word при открытии документа автоматически заменит текст-заполнитель реальным оглавлением, используя заголовки с уровнями структуры (outlineLvl), которые проставляет обработчик 40_final_formatting.py.

Добавление пустого абзаца – после поля TOC вставляется пустой абзац (стиль Normal) для создания визуального отступа перед следующим разделом. При необходимости его можно удалить или отключить.

Логирование – выводятся информационные сообщения о найденных индексах, количестве удалённых абзацев и факте вставки TOC.

Порядок выполнения:
Так как файл назван 43_generate_toc.py, он будет запущен после 42_remove_extra_empty_paragraphs.py, когда заголовки уже имеют уровни структуры (благодаря 40_final_formatting.py), а пустые абзацы уже нормализованы.

Важно:

Для корректной работы TOC необходимо, чтобы заголовки имели атрибут w:outlineLvl. Этот атрибут добавляется в обработчике 40_final_formatting.py (см. предыдущий ответ с модификацией этого обработчика).

Поле TOC будет обновляться при открытии документа в Word, если в настройках Word не отключено автоматическое обновление полей. При необходимости можно добавить инструкцию \* MERGEFORMAT или использовать другие флаги.

