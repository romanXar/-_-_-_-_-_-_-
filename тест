# main.py (дополненный функцией добавления нумерации через COM)
import os
import sys
import time
import shutil
import subprocess
import importlib
import pkgutil
from tkinter import Tk, filedialog, messagebox
from lxml import etree

from utils import docx_io, xml_utils
import handlers

def kill_word_processes():
    """Принудительно завершает все процессы Microsoft Word."""
    try:
        subprocess.run(['taskkill', '/f', '/im', 'winword.exe'], 
                       stdout=subprocess.DEVNULL, 
                       stderr=subprocess.DEVNULL)
        print("Все процессы Word завершены.")
    except Exception as e:
        print(f"Ошибка при завершении Word: {e}")

def run_preprocessor(input_path):
    """
    Запускает preprocessor.py как отдельный процесс.
    Возвращает путь к обработанному файлу (с суффиксом _normalized.docx).
    """
    preprocessor_path = os.path.join(os.path.dirname(__file__), 'preprocessor.py')
    if not os.path.exists(preprocessor_path):
        raise FileNotFoundError("preprocessor.py не найден в папке проекта")

    base, ext = os.path.splitext(input_path)
    output_path = f"{base}_normalized{ext}"

    print(f"Запуск preprocessor.py для преобразования нумерации...")
    result = subprocess.run(
        [sys.executable, preprocessor_path, input_path, output_path],
        capture_output=True,
        text=True
    )
    if result.returncode != 0:
        print("Ошибка при выполнении preprocessor.py:")
        print(result.stderr)
        raise RuntimeError("Препроцессор завершился с ошибкой")

    print("Препроцессор выполнен успешно.")
    print(result.stdout)
    return output_path

def add_page_numbers_via_com(docx_path):
    """
    Добавляет нижний колонтитул с номером страницы по центру (Times New Roman 14)
    через Microsoft Word (COM). Возвращает True в случае успеха.
    """
    try:
        import win32com.client
        from win32com.client import constants
    except ImportError:
        print("  Модуль win32com не установлен. Установите: pip install pywin32")
        return False

    word = None
    try:
        word = win32com.client.Dispatch("Word.Application")
        word.Visible = False
        word.DisplayAlerts = False

        doc = word.Documents.Open(docx_path)

        # Проходим по всем секциям документа
        for section in doc.Sections:
            footer = section.Footers(constants.wdHeaderFooterPrimary)
            footer.Range.Delete()  # удаляем старое содержимое
            footer.Range.ParagraphFormat.Alignment = constants.wdAlignParagraphCenter
            # Вставляем поле PAGE
            footer.Range.Fields.Add(footer.Range, constants.wdFieldEmpty, "PAGE", False)
            footer.Range.Font.Name = "Times New Roman"
            footer.Range.Font.Size = 14

        doc.Save()
        doc.Close()
        print("  Нумерация страниц успешно добавлена через Word.")
        return True
    except Exception as e:
        print(f"  Ошибка при добавлении нумерации через Word: {e}")
        return False
    finally:
        if word:
            word.Quit()

def load_handlers():
    """Загружает все обработчики из папки handlers, у которых есть функция process."""
    handlers_list = []
    for finder, name, ispkg in pkgutil.iter_modules(handlers.__path__):
        module = importlib.import_module(f'handlers.{name}')
        if hasattr(module, 'process'):
            handlers_list.append(module.process)
    # Сортируем по имени файла (для предсказуемого порядка)
    handlers_list.sort(key=lambda h: h.__module__)
    return handlers_list

def main():
    root = Tk()
    root.withdraw()

    input_path = filedialog.askopenfilename(
        title="Выберите DOCX-файл для обработки",
        filetypes=[("Word документы", "*.docx"), ("Все файлы", "*.*")]
    )
    if not input_path:
        print("Файл не выбран. Выход.")
        return

    print(f"Исходный файл: {input_path}")

    # Принудительно закрываем Word перед работой
    kill_word_processes()

    # Шаг 1: запускаем COM-препроцессор для конвертации нумерации
    try:
        normalized_path = run_preprocessor(input_path)
        print(f"Файл после препроцессора: {normalized_path}")
        time.sleep(1)  # даём Word время освободить файл
    except Exception as e:
        print(f"Ошибка на этапе препроцессора: {e}")
        messagebox.showerror("Ошибка", f"Препроцессор не сработал:\n{e}")
        return

    # Шаг 2: работаем с полученным файлом через XML-парсер
    temp_copy = docx_io.copy_docx(normalized_path)
    print(f"Копия для XML-обработки: {temp_copy}")

    temp_dir = docx_io.extract_docx(temp_copy)
    print(f"Распаковано во временную папку: {temp_dir}")

    result_path = None  # сохраним путь к итоговому файлу

    try:
        doc_path = os.path.join(temp_dir, 'word', 'document.xml')
        tree = etree.parse(doc_path)
        doc_root = tree.getroot()

        styles_path = os.path.join(temp_dir, 'word', 'styles.xml')
        styles_root = None
        if os.path.exists(styles_path):
            styles_tree = etree.parse(styles_path)
            styles_root = styles_tree.getroot()

        handlers_list = load_handlers()
        print(f"Загружено XML-обработчиков: {len(handlers_list)}")

        for handler in handlers_list:
            print(f"\n>>> Запуск {handler.__module__}")
            try:
                handler(doc_root, styles_root, log=print, temp_dir=temp_dir)
            except TypeError:
                handler(doc_root, styles_root, log=print)
            print(f"<<< Завершён {handler.__module__}")

        # Сохраняем изменения
        tree.write(doc_path, encoding='UTF-8', xml_declaration=True)
        if styles_root is not None:
            styles_tree.write(styles_path, encoding='UTF-8', xml_declaration=True)

        # Отладочная копия XML
        debug_xml_path = os.path.join(
            os.path.dirname(temp_copy),
            os.path.basename(temp_copy).replace('.docx', '_document.xml')
        )
        shutil.copy2(doc_path, debug_xml_path)
        print(f"Отладочная копия XML сохранена: {debug_xml_path}")

        # Упаковываем обратно в DOCX
        docx_io.pack_docx(temp_dir, temp_copy)
        result_path = temp_copy
        print(f"\nГотово! Результат сохранён в: {temp_copy}")

    except Exception as e:
        print(f"!!! Критическая ошибка при XML-обработке: {e}")
        messagebox.showerror("Ошибка", str(e))
    finally:
        docx_io.cleanup_temp(temp_dir)
        print("Временные файлы XML-этапа удалены.")

    # Шаг 3: добавляем нумерацию страниц через COM (если файл существует)
    if result_path and os.path.exists(result_path):
        print("\n>>> Добавление нумерации страниц через Word...")
        if add_page_numbers_via_com(result_path):
            print("Нумерация страниц успешно добавлена.")
            messagebox.showinfo("Готово", f"Файл успешно обработан и пронумерован:\n{result_path}")
        else:
            print("Не удалось добавить нумерацию страниц через Word.")
            messagebox.showwarning("Предупреждение", 
                                   "Файл обработан, но добавить нумерацию страниц не удалось.\n"
                                   "Вы можете сделать это вручную или проверить установку Microsoft Word.")
    else:
        messagebox.showinfo("Готово", f"Файл успешно обработан:\n{result_path}")

    # Предложение открыть файл
    if result_path and os.path.exists(result_path):
        if messagebox.askyesno("Открыть файл", "Открыть полученный файл?"):
            try:
                os.startfile(result_path)
            except Exception as e:
                print(f"Не удалось открыть файл: {e}")
                messagebox.showerror("Ошибка", f"Не удалось открыть файл:\n{e}")

if __name__ == "__main__":
