# handlers/43_generate_toc.py
import re
from lxml import etree
from utils import xml_utils

# Копируем функции определения заголовков из 40_final_formatting для согласованности
def is_structural_heading(text):
    """Структурный заголовок (капсом, не цифры)."""
    if len(text) < 3:
        return False
    return text.isupper() and not text.isdigit()

def is_heading(text):
    """Нумерованный заголовок (начинается с цифр)."""
    return re.match(r'^\d+(\.\d+)*\s', text) is not None

def create_toc_paragraph():
    """
    Создаёт абзац с полем TOC (оглавление) с инструкцией TOC \o "1-3" \h \z \u.
    Возвращает элемент w:p.
    """
    # Создаём корневой элемент абзаца
    p = etree.Element(xml_utils.tag('p'))

    # Свойства абзаца (можно добавить стиль Normal)
    pPr = etree.SubElement(p, xml_utils.tag('pPr'))
    pStyle = etree.SubElement(pPr, xml_utils.tag('pStyle'))
    pStyle.set(xml_utils.tag('val'), "Normal")

    # Начало поля
    r1 = etree.SubElement(p, xml_utils.tag('r'))
    fldChar1 = etree.SubElement(r1, xml_utils.tag('fldChar'))
    fldChar1.set(xml_utils.tag('fldCharType'), "begin")

    # Инструкция TOC (исправлено: экранированы обратные слеши)
    r2 = etree.SubElement(p, xml_utils.tag('r'))
    instrText = etree.SubElement(r2, xml_utils.tag('instrText'))
    instrText.set(xml_utils.NAMESPACE, "preserve")  # xml:space="preserve"
    instrText.text = 'TOC \\o "1-3" \\h \\z \\u'

    # Разделитель (separate)
    r3 = etree.SubElement(p, xml_utils.tag('r'))
    fldChar2 = etree.SubElement(r3, xml_utils.tag('fldChar'))
    fldChar2.set(xml_utils.tag('fldCharType'), "separate")

    # Текст-заполнитель (Word заменит его реальным оглавлением)
    r4 = etree.SubElement(p, xml_utils.tag('r'))
    t = etree.SubElement(r4, xml_utils.tag('t'))
    t.text = "Оглавление"

    # Конец поля
    r5 = etree.SubElement(p, xml_utils.tag('r'))
    fldChar3 = etree.SubElement(r5, xml_utils.tag('fldChar'))
    fldChar3.set(xml_utils.tag('fldCharType'), "end")

    return p

def process(doc_root, styles_root=None, log=print):
    """
    Ищет абзац с текстом «СОДЕРЖАНИЕ» (заголовок раздела оглавления).
    Если находит, удаляет всё содержимое между этим заголовком и следующим
    заголовком (структурным или нумерованным) и вставляет поле TOC сразу после
    заголовка «СОДЕРЖАНИЕ».
    """
    log(">>> Генерация оглавления (TOC)")

    paragraphs = xml_utils.find_all_paragraphs(doc_root)

    # Находим индекс абзаца с заголовком «СОДЕРЖАНИЕ»
    toc_title_idx = None
    for i, p in enumerate(paragraphs):
        text = xml_utils.get_paragraph_text(p).strip()
        # Сравниваем без учёта регистра и возможных лишних пробелов
        if text.upper() == "СОДЕРЖАНИЕ":
            toc_title_idx = i
            break

    if toc_title_idx is None:
        log("  Заголовок «СОДЕРЖАНИЕ» не найден, генерация TOC пропущена.")
        log("<<< Генерация оглавления завершена (без изменений)")
        return

    log(f"  Заголовок «СОДЕРЖАНИЕ» найден в абзаце #{toc_title_idx+1}")

