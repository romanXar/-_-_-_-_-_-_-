# handlers/45_insert_visible_page_breaks.py
from utils import xml_utils
from lxml import etree
import re

def is_heading(p):
    """Проверяет, является ли абзац заголовком раздела (капс или нумерованный)."""
    text = xml_utils.get_paragraph_text(p).strip()
    if not text:
        return False
    # Проверка на нумерованный заголовок (начинается с цифры)
    if re.match(r'^\d+(\.\d+)*\s', text):
        return True
    # Проверка на капс
    has_upper = any(ch.isalpha() for ch in text)
    if not has_upper:
        return False
    return not any(ch.islower() for ch in text)

def is_structural_heading(text):
    """Проверяет, является ли заголовок регламентированным (по списку или нумерованный)."""
    text_upper = text.strip().upper()
    # Точные названия
    if text_upper in ("РЕФЕРАТ", "СОДЕРЖАНИЕ", "ВВЕДЕНИЕ", "ЗАКЛЮЧЕНИЕ",
                       "СПИСОК СОКРАЩЕНИЙ", "СПИСОК ИСПОЛЬЗОВАННЫХ ИСТОЧНИКОВ"):
        return True
    # Приложения
    if text_upper.startswith("ПРИЛОЖЕНИЕ"):
        return True
    # Нумерованные заголовки (основная часть)
    if re.match(r'^\d+(\.\d+)*\s', text):
        return True
    return False

def is_numbered_heading(text):
    """Проверяет, является ли заголовок нумерованным."""
    return re.match(r'^\d+(\.\d+)*\s', text) is not None

def create_page_break_paragraph():
    """Создаёт пустой абзац с символом разрыва страницы."""
    p = etree.Element(xml_utils.tag('p'))
    r = etree.SubElement(p, xml_utils.tag('r'))
    br = etree.SubElement(r, xml_utils.tag('br'))
    br.set(xml_utils.tag('type'), 'page')
    return p

def process(doc_root, styles_root=None, log=print):
    log(">>> Вставка видимых разрывов страниц после регламентированных разделов (с учётом основной части)")

    paragraphs = xml_utils.find_all_paragraphs(doc_root)
    if not paragraphs:
        log("  Нет абзацев")
        return

    # Собираем все заголовки разделов с их индексами и свойствами
    headers = []
    for i, p in enumerate(paragraphs):
        text = xml_utils.get_paragraph_text(p).strip()
        if not text:
            continue
        if is_heading(p):
            headers.append({
                'index': i,
                'text': text,
                'structural': is_structural_heading(text),
                'numbered': is_numbered_heading(text)
            })

    if not headers:
        log("  Не найдено ни одного заголовка раздела")
        return

    log(f"  Найдено заголовков: {len(headers)}")

    modified = 0
    # Проходим по заголовкам, кроме последнего
    for j in range(len(headers)-1):
        current = headers[j]
        next_h = headers[j+1]

        # Если текущий заголовок не структурный, пропускаем
        if not current['structural']:
            continue

        # Определяем, нужно ли ставить разрыв
        need_break = True
        # Если текущий нумерованный и следующий тоже нумерованный - не ставим разрыв (они в одной основной части)
        if current['numbered'] and next_h['numbered']:
            need_break = False

        if not need_break:
            log(f"  Пропуск (внутри основной части) между '{current['text'][:30]}...' и '{next_h['text'][:30]}...'")
            continue

        # Определяем последний абзац текущего раздела (это абзац перед следующим заголовком)
        last_idx = next_h['index'] - 1
        if last_idx < current['index']:
            # Между заголовками нет абзацев? Тогда последний абзац - сам заголовок? Но разрыв ставить после заголовка? Лучше после заголовка, если нет текста.
            last_idx = current['index']

        last_p = paragraphs[last_idx]
        parent = last_p.getparent()
        pos = parent.index(last_p)

        # Проверяем, нет ли уже разрыва после этого абзаца
        if pos + 1 < len(parent):
            nxt = parent[pos+1]
            if nxt.find(f'.//{xml_utils.tag("br")}[@{xml_utils.tag("type")}="page"]') is not None:
                log(f"  Пропуск (разрыв уже есть) после раздела '{current['text'][:30]}...'")
                continue

        # Вставляем разрыв после последнего абзаца раздела
        break_para = create_page_break_paragraph()
        parent.insert(pos+1, break_para)
        modified += 1
        log(f"  Вставлен разрыв после раздела '{current['text'][:30]}...'")

    log(f"  Разрывов добавлено: {modified}")
    log("<<< Вставка видимых разрывов страниц завершена")
