# handlers/51_enable_table_headers.py
from utils import xml_utils
from lxml import etree

def tag(name):
    return xml_utils.tag(name)

def process(doc_root, styles_root=None, log=print, temp_dir=None):
    """
    Включает повторение заголовка для всех таблиц:
    - устанавливает атрибут w:tblHeader="true" для первой строки каждой таблицы
    - удаляет обтекание (w:tblpPr), если есть
    - настраивает w:tblLook для первой строки
    """
    log(">>> Включение повтора заголовков для всех таблиц (первая строка)")

    tables = doc_root.findall(f'.//{tag("tbl")}')
    if not tables:
        log("  Таблицы не найдены")
        return

    modified = 0
    for tbl in tables:
        # 1. Удаляем обтекание, если оно есть (блокирует повтор)
        tblPr = tbl.find(tag('tblPr'))
        if tblPr is not None:
            tblpPr = tblPr.find(tag('tblpPr'))
            if tblpPr is not None:
                tblPr.remove(tblpPr)
                log("  Удалено обтекание у таблицы")

        # 2. Настраиваем tblLook
        if tblPr is not None:
            tblLook = tblPr.find(tag('tblLook'))
            if tblLook is None:
                tblLook = etree.SubElement(tblPr, tag('tblLook'))
            # Устанавливаем атрибуты: firstRow=1, firstRowCondition=1
            tblLook.set(tag('firstRow'), '1')
            tblLook.set(tag('firstRowCondition'), '1')
            # Оставляем остальные атрибуты как есть или сбрасываем? Для надёжности установим val
            # val="04A0" означает: firstRow, lastRow, firstColumn, lastColumn применяются
            # Можно оставить как есть или установить стандартное значение
            if not tblLook.get(tag('val')):
                tblLook.set(tag('val'), '04A0')

        # 3. Устанавливаем заголовок на первой строке
        rows = tbl.findall(f'.//{tag("tr")}')
        if not rows:
            continue
        first_row = rows[0]
        if first_row.get(tag('tblHeader')) != 'true':
            first_row.set(tag('tblHeader'), 'true')
            modified += 1
            log(f"  Добавлен заголовок для таблицы #{modified}")

    log(f"  Обработано таблиц: {modified}")
    log("<<< Включение повтора заголовков завершено")
Этот обработчик должен гарантировать, что первая строка таблицы будет повторяться на каждой странице при разрыве. После его применения сохраните документ и снова конвертируйте в PDF для проверки. Если таблица всё ещё не разрывается, добавьте больше строк, чтобы принудительно вызвать разрыв.

