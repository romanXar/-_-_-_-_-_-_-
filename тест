🔧 Как это сделать программно (через Python)
Вы можете добавить в main.py функцию, которая будет открывать готовый DOCX через COM (как вы уже делаете с preprocessor.py и с добавлением нумерации) и сохранять его как PDF.

Вот пример такой функции:

python
def convert_to_pdf_via_com(docx_path, pdf_path=None):
    """
    Конвертирует DOCX-файл в PDF через Microsoft Word (COM).
    Если pdf_path не указан, создаёт PDF в той же папке с тем же именем.
    Возвращает путь к PDF или None в случае ошибки.
    """
    try:
        import win32com.client
        from win32com.client import constants
    except ImportError:
        print("  Модуль win32com не установлен. Установите: pip install pywin32")
        return None

    if pdf_path is None:
        pdf_path = docx_path.replace('.docx', '.pdf')

    word = None
    try:
        word = win32com.client.Dispatch("Word.Application")
        word.Visible = False
        word.DisplayAlerts = False

        doc = word.Documents.Open(docx_path)
        doc.SaveAs(pdf_path, FileFormat=constants.wdFormatPDF)  # 17 = PDF
        doc.Close()
        print(f"  PDF успешно создан: {pdf_path}")
        return pdf_path
    except Exception as e:
        print(f"  Ошибка при конвертации в PDF: {e}")
        return None
    finally:
        if word:
            word.Quit()
