def enable_table_headers_via_com(docx_path):
    import win32com.client
    from win32com.client import constants

    word = win32com.client.Dispatch("Word.Application")
    word.Visible = False
    word.DisplayAlerts = False

    doc = word.Documents.Open(docx_path)

    for table in doc.Tables:
        # Выбираем первую строку
        if table.Rows.Count > 0:
            table.Rows(1).HeadingFormat = True

    doc.Save()
    doc.Close()
    word.Quit()
Этот код нужно вставить после упаковки DOCX, но до конвертации в PDF. Тогда документ будет иметь правильно настроенные заголовки, и при конвертации в PDF они будут повторяться.

