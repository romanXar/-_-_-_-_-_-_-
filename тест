Более продвинутый вариант с pdfminer.six даёт доступ к координатам каждого текстового фрагмента :

python
from pdfminer.high_level import extract_pages
from pdfminer.layout import LTTextContainer

for page_layout in extract_pages("document.pdf"):
    print(f"Страница {page_layout.pageid}")
    for element in page_layout:
        if isinstance(element, LTTextContainer):
            text = element.get_text()
            x, y = element.x0, element.y0  # координаты
            print(f"  Текст '{text.strip()[:30]}...' на позиции ({x:.1f}, {y:.1f})")
