        if pos > 0 and parent[pos-1].find(f'.//{xml_utils.tag("br")}[@{xml_utils.tag("type")}="page"]') is not None:
            log(f"  Пропуск (разрыв уже есть) перед: '{xml_utils.get_paragraph_text(p)[:30]}...'")
            continue

