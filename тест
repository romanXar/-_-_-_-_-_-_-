# handlers/45_insert_visible_page_breaks.py
from utils import xml_utils
from lxml import etree

def is_heading(p):
    """Проверяет, является ли абзац заголовком раздела (написан капсом, содержит буквы)."""
    text = xml_utils.get_paragraph_text(p).strip()
    if not text:
        return False
    # Проверяем, что текст состоит только из заглавных букв, цифр и знаков препинания.
    # Для простоты: если есть хотя бы одна буква и все буквы заглавные.
    has_upper = any(ch.isalpha() for ch in text)
    if not has_upper:
        return False
    # Убедимся, что нет строчных букв.
    return not any(ch.islower() for ch in text)

def is_structural_heading(text):
    """Проверяет, является ли текст заголовка регламентированным."""
    text_upper = text.strip().upper()
    if text_upper in ("РЕФЕРАТ", "СОДЕРЖАНИЕ", "ВВЕДЕНИЕ", "ЗАКЛЮЧЕНИЕ",
                       "СПИСОК СОКРАЩЕНИЙ", "СПИСОК ИСПОЛЬЗОВАННЫХ ИСТОЧНИКОВ"):
        return True
    if text_upper.startswith("ПРИЛОЖЕНИЕ"):
        return True
    return False

def create_page_break_paragraph():
    """Создаёт пустой абзац с символом разрыва страницы."""
    p = etree.Element(xml_utils.tag('p'))
    r = etree.SubElement(p, xml_utils.tag('r'))
    br = etree.SubElement(r, xml_utils.tag('br'))
    br.set(xml_utils.tag('type'), 'page')
    return p

def has_page_break_before(p):
    """Проверяет, есть ли перед абзацем абзац с разрывом страницы."""
    parent = p.getparent()
    idx = parent.index(p)
    if idx > 0:
        prev = parent[idx-1]
        if prev.find(f'.//{xml_utils.tag("br")}[@{xml_utils.tag("type")}="page"]') is not None:
            return True
    return False

def process(doc_root, styles_root=None, log=print):
    log(">>> Вставка видимых разрывов страниц после регламентированных разделов")

    paragraphs = xml_utils.find_all_paragraphs(doc_root)
    if not paragraphs:
        log("  Нет абзацев")
        return

    # Находим все абзацы-заголовки разделов
    heading_indices = []
    for i, p in enumerate(paragraphs):
        if is_heading(p):
            heading_indices.append(i)

    if not heading_indices:
        log("  Не найдено ни одного заголовка раздела (капс)")
        return

    log(f"  Найдены заголовки разделов на позициях: {heading_indices}")

    modified = 0
    # Проходим по каждому заголовку, кроме последнего
    for idx_in_list in range(len(heading_indices)-1):
        start_idx = heading_indices[idx_in_list]          # индекс текущего заголовка
        end_idx = heading_indices[idx_in_list+1] - 1      # индекс последнего абзаца текущего раздела

        heading_p = paragraphs[start_idx]
        heading_text = xml_utils.get_paragraph_text(heading_p).strip()

        # Проверяем, регламентированный ли заголовок
        if not is_structural_heading(heading_text):
            log(f"  Пропуск (нерегламентированный) раздела '{heading_text[:30]}...'")
            continue

        # Теперь нужно вставить разрыв после абзаца с индексом end_idx
        # Но перед следующим заголовком (start_idx_next)
        # Получаем родителя и позицию последнего абзаца раздела
        last_p = paragraphs[end_idx]
        parent = last_p.getparent()
        pos = parent.index(last_p)

        # Проверяем, нет ли уже разрыва сразу после этого абзаца
        if pos + 1 < len(parent):
            nxt = parent[pos+1]
            if nxt.find(f'.//{xml_utils.tag("br")}[@{xml_utils.tag("type")}="page"]') is not None:
                log(f"  Пропуск (разрыв уже есть) после раздела '{heading_text[:30]}...'")
                continue

        # Вставляем разрыв после последнего абзаца
        break_para = create_page_break_paragraph()
        parent.insert(pos+1, break_para)
        modified += 1
        log(f"  Вставлен разрыв после раздела '{heading_text[:30]}...'")

    log(f"  Разрывов добавлено: {modified}")
    log("<<< Вставка видимых разрывов страниц завершена")
