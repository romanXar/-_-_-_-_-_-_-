from utils import xml_utils
from lxml import etree

def is_structural_element(text):
    """
    Проверяет, является ли текст заголовком структурного элемента,
    который должен начинаться с новой страницы.
    """
    text_upper = text.strip().upper()
    if text_upper in ("РЕФЕРАТ", "СОДЕРЖАНИЕ", "ВВЕДЕНИЕ", "ЗАКЛЮЧЕНИЕ", 
                       "СПИСОК СОКРАЩЕНИЙ", "СПИСОК ИСПОЛЬЗОВАННЫХ ИСТОЧНИКОВ"):
        return True
    if text_upper.startswith("ПРИЛОЖЕНИЕ"):
        return True
    return False

def create_page_break_paragraph():
    """
    Создаёт пустой абзац, содержащий только разрыв страницы (<w:br w:type="page"/>).
    """
    p = etree.Element(xml_utils.tag('p'))
    r = etree.SubElement(p, xml_utils.tag('r'))
    br = etree.SubElement(r, xml_utils.tag('br'))
    br.set(xml_utils.tag('type'), 'page')
    return p

def process(doc_root, styles_root=None, log=print):
    log(">>> Вставка видимых разрывов страниц перед структурными элементами (кроме первого абзаца)")

    paragraphs = xml_utils.find_all_paragraphs(doc_root)
    if not paragraphs:
        log("  Нет абзацев для обработки")
        return

    # Определяем родительский элемент (body)
    body = paragraphs[0].getparent()
    modified = 0

    # Проходим по абзацам с конца, чтобы не сбить индексы при вставке
    for i in range(len(paragraphs) - 1, -1, -1):
        p = paragraphs[i]
        text = xml_utils.get_paragraph_text(p).strip()

        if not text or not is_structural_element(text):
            continue

        # Находим индекс этого абзаца среди детей body
        parent = p.getparent()
        idx = parent.index(p)

        # Не вставляем разрыв перед самым первым абзацем документа
        if idx == 0:
            log(f"  Пропуск (первый абзац) перед: '{text[:30]}...'")
            continue

        # Проверяем, нет ли уже разрыва перед этим абзацем
        prev = parent[idx - 1]
        if prev.find(f'.//{xml_utils.tag("br")}[@{xml_utils.tag("type")}="page"]') is not None:
            log(f"  Пропуск (разрыв уже есть) перед: '{text[:30]}...'")
            continue

        # Вставляем новый абзац с разрывом
        break_para = create_page_break_paragraph()
        parent.insert(idx, break_para)
        modified += 1
        log(f"  Вставлен видимый разрыв перед: '{text[:30]}...'")

    log(f"  Разрывов добавлено: {modified}")
    log("<<< Вставка видимых разрывов страниц завершена")
