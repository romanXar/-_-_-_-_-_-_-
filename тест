# handlers/47_table_spacing.py
from utils import xml_utils
from lxml import etree

def is_table_caption(p):
    """Проверяет, является ли абзац названием таблицы."""
    text = xml_utils.get_paragraph_text(p).strip().lower()
    return text.startswith('таблица')

def is_empty_paragraph(p):
    """Проверяет, пустой ли абзац (нет текста, рисунков, таблиц)."""
    if xml_utils.get_paragraph_text(p).strip():
        return False
    if xml_utils.has_drawing(p):
        return False
    if xml_utils.has_table(p):
        return False
    return True

def is_regular_text(p):
    """Проверяет, является ли абзац обычным текстом (не пустой, не заголовок, не название таблицы)."""
    if is_empty_paragraph(p):
        return False
    text = xml_utils.get_paragraph_text(p).strip()
    if not text:
        return False
    # Исключаем заголовки (капс и нумерованные) и названия таблиц
    if text.isupper() or text.lower().startswith('таблица'):
        return False
    # Можно также исключить нумерованные заголовки, но они обычно капс или с цифрой, так что оставим
    return True

def create_empty_paragraph():
    """Создаёт пустой абзац."""
    p = etree.Element(xml_utils.tag('p'))
    pPr = etree.SubElement(p, xml_utils.tag('pPr'))
    pStyle = etree.SubElement(pPr, xml_utils.tag('pStyle'))
    pStyle.set(xml_utils.tag('val'), "Normal")
    ind = etree.SubElement(pPr, xml_utils.tag('ind'))
    ind.set(xml_utils.tag('firstLine'), "0")
    ind.set(xml_utils.tag('left'), "0")
    r = etree.SubElement(p, xml_utils.tag('r'))
    t = etree.SubElement(r, xml_utils.tag('t'))
    t.text = ""
    return p

def process(doc_root, styles_root=None, log=print):
    log(">>> Вставка пустых строк перед названиями таблиц и вокруг таблиц")

    body = doc_root.find(xml_utils.tag('body'))
    if body is None:
        log("  body не найден")
        return

    # Получаем все прямые дочерние элементы body
    children = list(body)

    # --- Шаг 1: Обработка названий таблиц (вставка пустой строки перед названием, если перед ним текст) ---
    modified_captions = 0
    i = 0
    while i < len(children):
        elem = children[i]
        if elem.tag == xml_utils.tag('p') and is_table_caption(elem):
            # Проверяем предыдущий элемент
            if i > 0:
                prev = children[i-1]
                if prev.tag == xml_utils.tag('p') and is_regular_text(prev):
                    # Вставляем пустой абзац перед названием
                    body.insert(i, create_empty_paragraph())
                    modified_captions += 1
                    log("  Вставлен пустой абзац перед названием таблицы")
                    # Обновляем список и смещаем индекс
                    children = list(body)
                    i += 1  # пропускаем вставленный пустой абзац
            # Переходим к следующему
        i += 1

    # --- Шаг 2: Обработка самих таблиц (вставка пустых строк перед и после таблицы, с учётом уже возможных пустых) ---
    # Снова получаем актуальный список детей
    children = list(body)
    # Находим все таблицы
    tables = []
    for i, elem in enumerate(children):
        if elem.tag == xml_utils.tag('tbl'):
            tables.append((i, elem))

    modified_tables = 0
    # Идём по таблицам в обратном порядке, чтобы не сбить индексы при вставке
    for pos, tbl in reversed(tables):
        # Вставка перед таблицей (учитываем, что перед таблицей может быть название и пустой абзац)
        if pos > 0:
            prev = children[pos-1]
            # Если предыдущий элемент не пустой абзац, вставляем пустой перед таблицей
            # Но осторожно: если перед таблицей название, то вставлять не надо, так как название уже может быть отделено пустым абзацем или нет.
            # Поскольку мы уже обработали названия, теперь перед таблицей может быть либо название, либо пустой абзац.
            # Если перед таблицей не пустой абзац (например, сразу название), то вставляем пустой перед таблицей? Нет, название должно быть сразу над таблицей без лишних пустых.
            # Правило: между названием и таблицей не должно быть пустых абзацев. Значит, если предыдущий элемент - название, то ничего не вставляем.
            # Если предыдущий элемент - что-то другое (текст, другая таблица и т.д.), то вставляем пустой.
            if prev.tag == xml_utils.tag('p') and is_table_caption(prev):
                # Перед таблицей название, ничего не делаем
                pass
            elif prev.tag != xml_utils.tag('p') or not is_empty_paragraph(prev):
                body.insert(pos, create_empty_paragraph())
                modified_tables += 1
                log("  Вставлен пустой абзац перед таблицей")
                # Поскольку вставили перед, позиция таблицы увеличивается, но мы идём с конца, так что не важно
        else:
            # Таблица в самом начале body – вставлять перед не нужно
            pass

        # Обновляем children, так как вставка перед могла сместить индексы
        children = list(body)
        # Находим новую позицию этой таблицы
        try:
            new_pos = children.index(tbl)
        except ValueError:
            continue

        # Вставка после таблицы
        if new_pos < len(children) - 1:
            nxt = children[new_pos + 1]
            # Если следующий элемент не пустой абзац, вставляем пустой после
            if nxt.tag != xml_utils.tag('p') or not is_empty_paragraph(nxt):
                body.insert(new_pos + 1, create_empty_paragraph())
                modified_tables += 1
                log("  Вставлен пустой абзац после таблицы")
                children = list(body)  # обновляем после вставки
        else:
            # Таблица в конце – не вставляем
            pass

    total = modified_captions + modified_tables
    log(f"  Добавлено пустых абзацев: перед названиями {modified_captions}, вокруг таблиц {modified_tables}, всего {total}")
    log("<<< Вставка пустых строк завершена")
Что изменилось
Обработчик теперь сначала проходит по всем элементам и вставляет пустую строку перед названием таблицы, если перед ним находится обычный текст (не пустой, не заголовок, не другое название).

Затем обрабатывает сами таблицы: вставляет пустую строку перед таблицей, только если перед ней не название и не пустой абзац (чтобы не дублировать).

Вставляет пустую строку после таблицы, если после неё не пустой абзац.

Все вставки делаются с учётом уже существующих пустых абзацев и не создают лишних.

