    new_table.style = table.style

    # Копируем заголовок (первую строку) в новую таблицу
    header_row = new_table.add_row()
    for j, src_cell in enumerate(rows[0].cells):
        header_row.cells[j].text = src_cell.text

    # Копируем строки с split_row до конца
    for i in range(split_row, len(rows)):
        src_row = rows[i]
        dst_row = new_table.add_row()
        for j, src_cell in enumerate(src_row.cells):
            dst_row.cells[j].text = src_cell.text

    # Удаляем скопированные строки из исходной таблицы
    for i in range(len(rows) - 1, split_row - 1, -1):
        tr = rows[i]._tr
        tr.getparent().remove(tr)

    return new_table
