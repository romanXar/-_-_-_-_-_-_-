python
# handlers/45_insert_visible_page_breaks.py
from utils import xml_utils
from lxml import etree
import re

def is_heading(p):
    """Проверяет, является ли абзац заголовком раздела (капс или нумерованный)."""
    text = xml_utils.get_paragraph_text(p).strip()
    if not text:
        return False
    if re.match(r'^\d+(\.\d+)*\s', text):
        return True
    has_upper = any(ch.isalpha() for ch in text)
    if not has_upper:
        return False
    return not any(ch.islower() for ch in text)

def is_structural_heading(text):
    """Проверяет, является ли заголовок регламентированным."""
    text_upper = text.strip().upper()
    if text_upper in ("РЕФЕРАТ", "СОДЕРЖАНИЕ", "ВВЕДЕНИЕ", "ЗАКЛЮЧЕНИЕ",
                      "СПИСОК СОКРАЩЕНИЙ", "СПИСОК ИСПОЛЬЗОВАННЫХ ИСТОЧНИКОВ"):
        return True
    if text_upper.startswith("ПРИЛОЖЕНИЕ"):
        return True
    if re.match(r'^\d+(\.\d+)*\s', text):
        return True
    return False

def is_numbered_heading(text):
    return re.match(r'^\d+(\.\d+)*\s', text) is not None

def is_empty_paragraph(p):
    """Проверяет, является ли абзац пустым (нет текста, рисунков, таблиц)."""
    if xml_utils.get_paragraph_text(p).strip():
        return False
    if xml_utils.has_drawing(p):
        return False
    if xml_utils.has_table(p):
        return False
    return True

def add_page_break_to_paragraph(p):
    """Добавляет символ разрыва страницы в конец прогонов абзаца."""
    # Ищем последний прогон или создаём новый
    runs = p.findall(xml_utils.tag('r'))
    if runs:
        r = runs[-1]
    else:
        r = etree.SubElement(p, xml_utils.tag('r'))
    br = etree.SubElement(r, xml_utils.tag('br'))
    br.set(xml_utils.tag('type'), 'page')

def process(doc_root, styles_root=None, log=print):
    log(">>> Вставка разрывов страниц в последний абзац регламентированных разделов")

    paragraphs = xml_utils.find_all_paragraphs(doc_root)
    if not paragraphs:
        log("  Нет абзацев")
        return

    # Собираем все заголовки
    headers = []
    for i, p in enumerate(paragraphs):
        text = xml_utils.get_paragraph_text(p).strip()
        if text and is_heading(p):
            headers.append({
                'index': i,
                'text': text,
                'structural': is_structural_heading(text),
                'numbered': is_numbered_heading(text)
            })

    if not headers:
        log("  Не найдено заголовков")
        return

    log(f"  Найдено заголовков: {len(headers)}")

    modified = 0
    # Проходим по заголовкам, кроме первого
    for j in range(1, len(headers)):
        prev = headers[j-1]
        curr = headers[j]

        # Если предыдущий заголовок не структурный — пропускаем
        if not prev['structural']:
            continue

        # Определяем, нужен ли разрыв между предыдущим и текущим
        need_break = True
        if prev['numbered'] and curr['numbered']:
            need_break = False

        if not need_break:
            log(f"  Пропуск (внутри основной части) между '{prev['text'][:30]}...' и '{curr['text'][:30]}...'")
            continue

        # Находим последний абзац предыдущего раздела (перед curr['index'])
        # Это либо prev['index'] (если между ними нет абзацев), либо последний непустой перед curr
        last_content_idx = curr['index'] - 1
        # Идём назад от curr['index']-1 до prev['index'] и ищем последний непустой (не заголовок)
        # Но если все абзацы между ними пустые, то last_content_idx останется prev['index'] (сам заголовок)
        for k in range(curr['index']-1, prev['index']-1, -1):
            if not is_empty_paragraph(paragraphs[k]):
                last_content_idx = k
                break
        else:
            # Если не нашли непустого, берём предыдущий заголовок
            last_content_idx = prev['index']

        last_p = paragraphs[last_content_idx]
        parent = last_p.getparent()

        # Удаляем все пустые абзацы между last_p и curr['index']
        # Но проще: после вставки разрыва они могут остаться, но разрыв уже в last_p
        # Однако чтобы избежать лишних пустых абзацев на новой странице, удалим все пустые между ними
        to_delete = []
        for k in range(last_content_idx+1, curr['index']):
            if is_empty_paragraph(paragraphs[k]):
                to_delete.append(paragraphs[k])
        # Удаляем с конца, чтобы не сбить индексы
        for p_del in reversed(to_delete):
            parent.remove(p_del)
            log(f"    Удалён пустой абзац между разделами")

        # Добавляем разрыв в last_p (если его там ещё нет)
        if last_p.find(f'.//{xml_utils.tag("br")}[@{xml_utils.tag("type")}="page"]') is None:
            add_page_break_to_paragraph(last_p)
            modified += 1
            log(f"  Вставлен разрыв в последний абзац раздела '{prev['text'][:30]}...'")
        else:
            log(f"  Пропуск (разрыв уже есть) в последнем абзаце раздела '{prev['text'][:30]}...'")

    log(f"  Разрывов добавлено: {modified}")
    log("<<< Вставка разрывов страниц завершена")
