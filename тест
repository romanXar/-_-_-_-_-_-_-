python
# handlers/43_generate_toc.py
from lxml import etree
from utils import xml_utils
import re

def is_heading(p):
    """Определяет, является ли абзац заголовком (структурный или нумерованный) по тексту."""
    text = xml_utils.get_paragraph_text(p).strip()
    if not text:
        return False
    # структурный заголовок (капсом, не цифры)
    if len(text) >= 3 and text.isupper() and not text.isdigit():
        return True
    # нумерованный заголовок (начинается с цифр)
    if re.match(r'^\d+(\.\d+)*\s', text):
        return True
    return False

def find_next_heading(paragraphs, start_idx):
    """Ищет следующий заголовок, начиная с индекса start_idx+1 (0-based). Возвращает индекс или None."""
    for i in range(start_idx+1, len(paragraphs)):
        if is_heading(paragraphs[i]):
            return i
    return None

def create_toc_field_paragraph():
    """Создаёт абзац с полем TOC \u."""
    # Создаём новый элемент p
    p = etree.Element(xml_utils.tag('p'))
    
    # Добавляем свойства (стиль Normal, отступы 0)
    pPr = etree.SubElement(p, xml_utils.tag('pPr'))
    pStyle = etree.SubElement(pPr, xml_utils.tag('pStyle'))
    pStyle.set(xml_utils.tag('val'), "Normal")
    ind = etree.SubElement(pPr, xml_utils.tag('ind'))
    ind.set(xml_utils.tag('firstLine'), "0")
    ind.set(xml_utils.tag('left'), "0")
    
    # Начало поля
    r1 = etree.SubElement(p, xml_utils.tag('r'))
    fldChar1 = etree.SubElement(r1, xml_utils.tag('fldChar'))
    fldChar1.set(xml_utils.tag('fldCharType'), "begin")
    
    # Инструкция
    r2 = etree.SubElement(p, xml_utils.tag('r'))
    instr = etree.SubElement(r2, xml_utils.tag('instrText'))
    instr.text = 'TOC \\u'
    
    # Разделитель
    r3 = etree.SubElement(p, xml_utils.tag('r'))
    fldChar2 = etree.SubElement(r3, xml_utils.tag('fldChar'))
    fldChar2.set(xml_utils.tag('fldCharType'), "separate")
    
    # Заполнитель (будет заменён при обновлении поля)
    r4 = etree.SubElement(p, xml_utils.tag('r'))
    t = etree.SubElement(r4, xml_utils.tag('t'))
    t.text = "Оглавление"
    
    # Конец поля
    r5 = etree.SubElement(p, xml_utils.tag('r'))
    fldChar3 = etree.SubElement(r5, xml_utils.tag('fldChar'))
    fldChar3.set(xml_utils.tag('fldCharType'), "end")
    
    return p

