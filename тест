def fix_table_headers_and_breaks(docx_path):
    import win32com.client
    word = win32com.client.Dispatch("Word.Application")
    word.Visible = False
    doc = word.Documents.Open(docx_path)
    
    for table in doc.Tables:
        # Включаем повтор заголовка
        if table.Rows.Count > 0:
            table.Rows(1).HeadingFormat = True
        
        # Находим таблицы, которые переносятся
        first_row = table.Rows(1)
        last_row = table.Rows(table.Rows.Count)
        
        first_row.Range.Select()
        first_page = word.Selection.Information(3)  # wdActiveEndPageNumber
        
        last_row.Range.Select()
        last_page = word.Selection.Information(3)
        
