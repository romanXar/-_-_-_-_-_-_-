                modified += 1
                log(f"  Вставлен пустой абзац после таблицы")
                children = list(body)  # обновляем для следующей итерации

        # Переходим к следующей таблице в исходном списке, но учитываем, что индексы могли измениться
        i += 1
        # Обновляем список детей для следующей итерации
        children = list(body)

    log(f"  Добавлено пустых абзацев: {modified}")
    log("<<< Вставка пустых строк завершена")
