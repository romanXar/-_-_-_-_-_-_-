# handlers/48_add_page_numbers.py
import os
from lxml import etree
from utils import xml_utils

# Пространства имён
NS_REL = 'http://schemas.openxmlformats.org/officeDocument/2006/relationships'
NS_W = xml_utils.NAMESPACE
NS_XML = 'http://www.w3.org/XML/1998/namespace'
NS_TYPES = 'http://schemas.openxmlformats.org/package/2006/content-types'

def tag(name):
    return f'{{{NS_W}}}{name}'

def create_footer_xml(footer_path):
    """Создаёт файл footer.xml с номером страницы по центру (Times New Roman 14pt)."""
    root = etree.Element(tag('ftr'), nsmap={'w': NS_W})
    # Абзац
    p = etree.SubElement(root, tag('p'))
    pPr = etree.SubElement(p, tag('pPr'))
    jc = etree.SubElement(pPr, tag('jc'))
    jc.set(tag('val'), 'center')
    # Свойства шрифта
    rPr = etree.SubElement(pPr, tag('rPr'))
    rFonts = etree.SubElement(rPr, tag('rFonts'))
    rFonts.set(tag('ascii'), 'Times New Roman')
    rFonts.set(tag('hAnsi'), 'Times New Roman')
    rFonts.set(tag('cs'), 'Times New Roman')
    sz = etree.SubElement(rPr, tag('sz'))
    sz.set(tag('val'), '28')
    szCs = etree.SubElement(rPr, tag('szCs'))
    szCs.set(tag('val'), '28')

    # Поле PAGE
    r = etree.SubElement(p, tag('r'))
    fldChar = etree.SubElement(r, tag('fldChar'))
    fldChar.set(tag('fldCharType'), 'begin')

    r2 = etree.SubElement(p, tag('r'))
    instrText = etree.SubElement(r2, tag('instrText'))
    instrText.set(f'{{{NS_XML}}}space', 'preserve')
    instrText.text = 'PAGE'

    r3 = etree.SubElement(p, tag('r'))
    fldChar2 = etree.SubElement(r3, tag('fldChar'))
    fldChar2.set(tag('fldCharType'), 'separate')

    r4 = etree.SubElement(p, tag('r'))
    t = etree.SubElement(r4, tag('t'))
    t.text = '1'

    r5 = etree.SubElement(p, tag('r'))
    fldChar3 = etree.SubElement(r5, tag('fldChar'))
    fldChar3.set(tag('fldCharType'), 'end')

    tree = etree.ElementTree(root)
    tree.write(footer_path, encoding='UTF-8', xml_declaration=True)

def update_document_rels(rels_path):
    """Добавляет отношение к footer.xml в document.xml.rels, возвращает id отношения."""
    if os.path.exists(rels_path):
        tree = etree.parse(rels_path)
        root = tree.getroot()
        # Ищем максимальный id
        max_id = 0
        for rel in root.findall(f'{{{NS_REL}}}Relationship'):
            rid = rel.get('Id')
            if rid and rid.startswith('rId'):
                try:
                    num = int(rid[3:])
                    if num > max_id:
                        max_id = num
                except:
                    pass
        new_id = f'rId{max_id + 1}'
    else:
        root = etree.Element('Relationships', xmlns=NS_REL)
        new_id = 'rId1'

    # Добавляем отношение
    rel_elem = etree.SubElement(root, 'Relationship')
    rel_elem.set('Id', new_id)
    rel_elem.set('Type', 'http://schemas.openxmlformats.org/officeDocument/2006/relationships/footer')
    rel_elem.set('Target', 'footer.xml')

    tree = etree.ElementTree(root)
    tree.write(rels_path, encoding='UTF-8', xml_declaration=True)
    return new_id

def update_content_types(content_types_path):
    """Добавляет запись для footer.xml в [Content_Types].xml, если её нет."""
    if not os.path.exists(content_types_path):
        # Если файла нет, создаём базовый (такого быть не должно, но на всякий случай)
        root = etree.Element('Types', xmlns=NS_TYPES)
        # Добавляем стандартные типы? Но проще не создавать.
        # Лучше вернуть ошибку.
        print("  [Content_Types].xml не найден!")
        return

    tree = etree.parse(content_types_path)
    root = tree.getroot()
    # Проверяем, есть ли уже запись для footer.xml
    xpath = f'{{{NS_TYPES}}}Override[@PartName="/word/footer.xml"]'
    if root.find(xpath) is not None:
        return  # уже есть

    # Добавляем
    override = etree.SubElement(root, 'Override')
    override.set('PartName', '/word/footer.xml')
    override.set('ContentType', 'application/vnd.openxmlformats-officedocument.wordprocessingml.footer+xml')
    tree.write(content_types_path, encoding='UTF-8', xml_declaration=True)

def process(doc_root, styles_root=None, log=print, temp_dir=None):
    log(">>> Добавление нумерации страниц (нижний колонтитул)")

    if temp_dir is None:
        log("  Ошибка: не указана временная папка (temp_dir)")
        return

    word_dir = os.path.join(temp_dir, 'word')
    if not os.path.exists(word_dir):
        log("  Папка word не найдена")
        return

    # Удаляем старые файлы footer*.xml
    for fname in os.listdir(word_dir):
        if fname.startswith('footer') and fname.endswith('.xml'):
            os.remove(os.path.join(word_dir, fname))
            log(f"  Удалён старый файл: {fname}")

    # Создаём новый footer.xml
    footer_path = os.path.join(word_dir, 'footer.xml')
    create_footer_xml(footer_path)
    log("  Создан footer.xml")

    # Обновляем document.xml.rels
    rels_path = os.path.join(word_dir, '_rels', 'document.xml.rels')
    os.makedirs(os.path.dirname(rels_path), exist_ok=True)
    rel_id = update_document_rels(rels_path)
    log(f"  Добавлено отношение с id={rel_id}")

    # Обновляем [Content_Types].xml
    content_types_path = os.path.join(temp_dir, '[Content_Types].xml')
    update_content_types(content_types_path)
    log("  [Content_Types].xml обновлён (добавлен footer.xml)")

    # Обновляем document.xml
    doc_path = os.path.join(word_dir, 'document.xml')
    if not os.path.exists(doc_path):
        log("  document.xml не найден")
        return

    doc_tree = etree.parse(doc_path)
    doc_root_local = doc_tree.getroot()

    sectPr_list = doc_root_local.findall(f'.//{tag("sectPr")}')
    if not sectPr_list:
        body = doc_root_local.find(tag('body'))
        if body is not None:
            sectPr = etree.SubElement(body, tag('sectPr'))
            sectPr_list = [sectPr]

    for sectPr in sectPr_list:
        # Удаляем старые ссылки на нижние колонтитулы
        for footerRef in sectPr.findall(tag('footerReference')):
            sectPr.remove(footerRef)
        # Добавляем новую
        footer_ref = etree.SubElement(sectPr, tag('footerReference'))
        footer_ref.set(tag('type'), 'default')
        footer_ref.set(f'{{{NS_REL}}}id', rel_id)

    doc_tree.write(doc_path, encoding='UTF-8', xml_declaration=True)
    log("  document.xml обновлён (добавлены ссылки на footer)")

    log("<<< Добавление нумерации страниц завершено")
