def map_table_rows_to_pages(docx_tables, pdf_pages):
    table_page_map = []
    
    for table in docx_tables:
        table_info = {
            'index': table['index'],
            'rows': [],
            'page_breaks': []  # здесь будем хранить, где разорвано
        }
        
        current_page = None
        last_page = None
        
        for row_text in table['rows']:
            # Ищем эту строку на страницах PDF
            found_on_page = None
            for page_data in pdf_pages:
                # Ищем точное совпадение ячейки
                if any(row_text in cell for cell in page_data['cells']):
                    found_on_page = page_data['page']
                    break
            
            if found_on_page:
                if current_page is None:
                    current_page = found_on_page
                elif found_on_page != current_page:
                    # Обнаружен разрыв страницы!
                    table_info['page_breaks'].append({
                        'row': row_text,
                        'from_page': current_page,
                        'to_page': found_on_page
                    })
                    current_page = found_on_page
            
            table_info['rows'].append({
                'text': row_text,
                'page': found_on_page
            })
        
        table_page_map.append(table_info)
    
    return table_page_map
