# handlers/47_table_spacing.py
from utils import xml_utils
from lxml import etree

def is_table_caption(p):
    """Проверяет, является ли абзац названием таблицы."""
    text = xml_utils.get_paragraph_text(p).strip().lower()
    return text.startswith('таблица')

def is_heading(p):
    """Проверяет, является ли абзац заголовком (капс или нумерованный)."""
    text = xml_utils.get_paragraph_text(p).strip()
    if not text:
        return False
    # Простейшая проверка: если текст не пустой и не название таблицы
    return not is_table_caption(p)

def is_empty_paragraph(p):
    """Проверяет, пустой ли абзац."""
    if xml_utils.get_paragraph_text(p).strip():
        return False
    if xml_utils.has_drawing(p):
        return False
    if xml_utils.has_table(p):
        return False
    return True

def create_empty_paragraph(with_keepNext=False):
    """Создаёт пустой абзац со стилем Normal и нулевыми отступами."""
    p = etree.Element(xml_utils.tag('p'))
    pPr = etree.SubElement(p, xml_utils.tag('pPr'))
    pStyle = etree.SubElement(pPr, xml_utils.tag('pStyle'))
    pStyle.set(xml_utils.tag('val'), "Normal")
    ind = etree.SubElement(pPr, xml_utils.tag('ind'))
    ind.set(xml_utils.tag('firstLine'), "0")
    ind.set(xml_utils.tag('left'), "0")
    if with_keepNext:
        etree.SubElement(pPr, xml_utils.tag('keepNext'))
    r = etree.SubElement(p, xml_utils.tag('r'))
    t = etree.SubElement(r, xml_utils.tag('t'))
    t.text = ""
    return p

def process(doc_root, styles_root=None, log=print):
    log(">>> Вставка пустых строк до и после таблиц")

    body = doc_root.find(xml_utils.tag('body'))
    if body is None:
        log("  Нет body")
        return

    # Собираем все элементы внутри body для анализа соседей
    children = list(body)
    tables = body.findall(f'.//{xml_utils.tag("tbl")}')
    log(f"  Найдено таблиц: {len(tables)}")

    modified = 0
    # Для каждой таблицы нужно найти её позицию среди детей body
    for tbl in tables:
        # Находим индекс таблицы среди детей body
        try:
            idx = children.index(tbl)
        except ValueError:
            continue  # на всякий случай

        # --- Вставка перед таблицей ---
        if idx > 0:
            prev = children[idx - 1]
            # Если предыдущий элемент не абзац, пропускаем (но обычно там только абзацы или таблицы)
            if prev.tag == xml_utils.tag('p'):
                # Если предыдущий абзац пустой или является названием таблицы, не вставляем
                if not is_empty_paragraph(prev) and not is_table_caption(prev):
                    # Вставляем пустой абзац перед таблицей
                    empty_p = create_empty_paragraph(with_keepNext=False)
                    body.insert(idx, empty_p)
                    modified += 1
                    log(f"  Вставлен пустой абзац перед таблицей (индекс {idx})")
            else:
                # Если предыдущий элемент не абзац (например, другая таблица), всё равно вставим пустой абзац
                empty_p = create_empty_paragraph(with_keepNext=False)
                body.insert(idx, empty_p)
                modified += 1
                log(f"  Вставлен пустой абзац перед таблицей (индекс {idx})")
        else:
            # Таблица в самом начале body – вставлять перед ней не нужно
            log("  Таблица в начале body, пропуск вставки перед")

        # После вставки перед таблицей индексы сместились, поэтому пересобираем children
        children = list(body)
        # Находим новое положение таблицы
        try:
            idx = children.index(tbl)
        except ValueError:
            continue

        # --- Вставка после таблицы ---
        if idx < len(children) - 1:
            nxt = children[idx + 1]
            if nxt.tag == xml_utils.tag('p'):
                # Если следующий абзац пустой или является заголовком/подписью, не вставляем
                if not is_empty_paragraph(nxt) and not is_heading(nxt):
                    empty_p = create_empty_paragraph(with_keepNext=True)
                    body.insert(idx + 1, empty_p)
                    modified += 1
                    log(f"  Вставлен пустой абзац после таблицы (индекс {idx})")
            else:
                # Если следующий элемент не абзац (например, другая таблица), вставим пустой абзац
                empty_p = create_empty_paragraph(with_keepNext=True)
                body.insert(idx + 1, empty_p)
                modified += 1
                log(f"  Вставлен пустой абзац после таблицы (индекс {idx})")
        else:
            log("  Таблица в конце body, пропуск вставки после")

        # После вставки после таблицы снова пересобираем children для следующих итераций
        children = list(body)

    log(f"  Пустых абзацев добавлено вокруг таблиц: {modified}")
    log("<<< Вставка пустых строк до и после таблиц завершена")
