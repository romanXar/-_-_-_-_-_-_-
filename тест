# Псевдокод, иллюстрирующий процесс
def split_table_at_row(docx_path, table_index, split_row_index):
    # 1. Загружаем документ
    doc = Document(docx_path)
    
    # 2. Находим нужную таблицу
    table = doc.tables[table_index]
    
    # 3. Создаём новую таблицу
    new_table = doc.add_table(rows=0, cols=len(table.columns))
    
    # 4. Копируем строки, начиная с split_row_index
    for i in range(split_row_index, len(table.rows)):
        # Копируем содержимое каждой ячейки
        new_row = new_table.add_row()
        for j, cell in enumerate(table.rows[i].cells):
            new_row.cells[j].text = cell.text
    
    # 5. Удаляем скопированные строки из исходной таблицы
    # (удаляем с конца, чтобы не сбивать индексы)
    for i in range(len(table.rows) - 1, split_row_index - 1, -1):
        # В python-docx нет прямого удаления строк, нужно через low-level XML
        delete_table_row(table, i)
    
    # 6. Сохраняем документ
    doc.save('modified.docx')
