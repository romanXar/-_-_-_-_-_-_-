import pdfplumber

def extract_pdf_pages_with_tables(pdf_path):
    pages_content = []
    
    with pdfplumber.open(pdf_path) as pdf:
        for page_num, page in enumerate(pdf.pages, 1):
            # Извлекаем все таблицы с этой страницы
            tables = page.extract_tables()
            
            # Также извлекаем обычный текст для контекста
            text = page.extract_text()
            
            # Собираем все ячейки со страницы в плоский список
            page_cells = []
            for table in tables:
                for row in table:
                    for cell in row:
                        if cell and cell.strip():
                            page_cells.append(cell.strip())
            
            pages_content.append({
                'page': page_num,
                'text': text,
                'cells': page_cells,
                'raw_tables': tables  # сохраняем структуру
            })
    
    return pages_content
