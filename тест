# handlers/51_enable_table_headers.py
from utils import xml_utils
from lxml import etree

def tag(name):
    return xml_utils.tag(name)

def process(doc_root, styles_root=None, log=print, temp_dir=None):
    """
    Включает повторение заголовка для всех таблиц:
    устанавливает атрибут w:tblHeader="true" для первой строки каждой таблицы.
    Это временная мера для последующего анализа PDF.
    """
    log(">>> Включение повтора заголовков для всех таблиц (первая строка)")

    # Находим все таблицы
    tables = doc_root.findall(f'.//{tag("tbl")}')
    if not tables:
        log("  Таблицы не найдены")
        return

    modified = 0
    for tbl in tables:
        # Находим первую строку таблицы
        rows = tbl.findall(f'.//{tag("tr")}')
        if not rows:
            continue
        first_row = rows[0]

        # Проверяем, установлен ли уже атрибут
        if first_row.get(tag('tblHeader')) == 'true':
            continue

        # Устанавливаем атрибут
        first_row.set(tag('tblHeader'), 'true')
        modified += 1
        log(f"  Добавлен заголовок для таблицы #{modified}")

    log(f"  Обработано таблиц: {modified}")
    log("<<< Включение повтора заголовков завершено")
