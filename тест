# handlers/05_apply_normal_style.py
from utils import xml_utils

TIMES_NEW_ROMAN = "Times New Roman"
FONT_SIZE = 28          # 14 pt в half-points
LINE_SPACING = "360"    # полуторный (в 240-х долях)
ALIGNMENT = "both"      # по ширине

def find_or_create_normal_style(styles_root, log):
    """Находит стиль по умолчанию (атрибут default="1") или создаёт его."""
    if styles_root is None:
        return None

    for style in styles_root.findall(f'.//{xml_utils.tag("style")}'):
        if style.get(xml_utils.tag('type')) == "paragraph" and style.get(xml_utils.tag('default')) == "1":
            log(f"  Найден стиль по умолчанию: {style.get(xml_utils.tag('styleId'))}")
            return style

    log("  Стиль по умолчанию не найден, создаём Normal")
    style = styles_root.makeelement(xml_utils.tag('style'))
    style.set(xml_utils.tag('type'), "paragraph")
    style.set(xml_utils.tag('styleId'), "Normal")
    style.set(xml_utils.tag('default'), "1")
    name = style.makeelement(xml_utils.tag('name'))
    name.set(xml_utils.tag('val'), "Обычный")
    style.append(name)
    styles_root.insert(0, style)
    return style

def setup_normal_style(style, log):
    """Задаёт параметры шрифта и абзаца для стиля Normal."""
    # Шрифт
    rPr = style.find(xml_utils.tag('rPr'))
    if rPr is None:
        rPr = style.makeelement(xml_utils.tag('rPr'))
        style.append(rPr)

    fonts = rPr.find(xml_utils.tag('rFonts'))
    if fonts is None:
        fonts = rPr.makeelement(xml_utils.tag('rFonts'))
        rPr.append(fonts)
    fonts.set(xml_utils.tag('ascii'), TIMES_NEW_ROMAN)
    fonts.set(xml_utils.tag('hAnsi'), TIMES_NEW_ROMAN)
    fonts.set(xml_utils.tag('cs'), TIMES_NEW_ROMAN)

    sz = rPr.find(xml_utils.tag('sz'))
    if sz is None:
        sz = rPr.makeelement(xml_utils.tag('sz'))
        rPr.append(sz)
    sz.set(xml_utils.tag('val'), str(FONT_SIZE))

    szCs = rPr.find(xml_utils.tag('szCs'))
    if szCs is None:
        szCs = rPr.makeelement(xml_utils.tag('szCs'))
        rPr.append(szCs)
    szCs.set(xml_utils.tag('val'), str(FONT_SIZE))

    # Параграф
    pPr = style.find(xml_utils.tag('pPr'))
    if pPr is None:
        pPr = style.makeelement(xml_utils.tag('pPr'))
        style.append(pPr)

    jc = pPr.find(xml_utils.tag('jc'))
    if jc is None:
        jc = pPr.makeelement(xml_utils.tag('jc'))
        pPr.append(jc)
    jc.set(xml_utils.tag('val'), ALIGNMENT)

    spacing = pPr.find(xml_utils.tag('spacing'))
    if spacing is None:
        spacing = pPr.makeelement(xml_utils.tag('spacing'))
        pPr.append(spacing)
    spacing.set(xml_utils.tag('line'), LINE_SPACING)
    spacing.set(xml_utils.tag('lineRule'), "auto")
    # Добавляем явную установку after="0"
    spacing.set(xml_utils.tag('after'), "0")
    # При необходимости можно также before="0"
    # spacing.set(xml_utils.tag('before'), "0")

    ind = pPr.find(xml_utils.tag('ind'))
    if ind is None:
        ind = pPr.makeelement(xml_utils.tag('ind'))
        pPr.append(ind)
    ind.set(xml_utils.tag('left'), "0")
    ind.set(xml_utils.tag('right'), "0")
    ind.set(xml_utils.tag('firstLine'), "0")

def process(doc_root, styles_root=None, log=print):
    """
    Применяет единый стиль Normal ко всем абзацам вне титульника и таблиц.
    Настраивает стиль Normal в styles.xml.
    """
    log(">>> Применение единого стиля Normal")

    # 1. Настраиваем стиль Normal в styles.xml
    if styles_root is not None:
        normal_style = find_or_create_normal_style(styles_root, log)
        if normal_style is not None:
            setup_normal_style(normal_style, log)
            log("  Стиль Normal обновлён")
        else:
            log("  Не удалось найти или создать стиль Normal")
    else:
        log("  styles.xml не загружен, пропускаем настройку стиля")

    # 2. Применяем стиль Normal к абзацам (кроме титульника и таблиц)
    paragraphs = xml_utils.find_all_paragraphs(doc_root)
    title_end = xml_utils.find_title_end_index(paragraphs)
    if title_end > 0:
        log(f"Титульник заканчивается на абзаце #{title_end}, обрабатываем с #{title_end+1}")
    else:
        log("Титульник не найден, обрабатываем всё")
        title_end = 0

    log(f"Найдено абзацев для сброса стилей: {len(paragraphs)}")

    modified = 0
    for idx, p in enumerate(paragraphs, 1):
        if idx <= title_end:
            continue
        try:
            if xml_utils.is_inside_table(p):
                continue

            # Работа с pPr
            pPr = p.find(xml_utils.tag('pPr'))
            if pPr is not None:
                for child in list(pPr):
                    if child.tag != xml_utils.tag('pStyle'):
                        pPr.remove(child)
                if len(pPr) == 0 and not pPr.attrib:
                    p.remove(pPr)
                    pPr = None
            if pPr is None:
                pPr = p.makeelement(xml_utils.tag('pPr'))
                p.insert(0, pPr)

            pStyle = pPr.find(xml_utils.tag('pStyle'))
            if pStyle is None:
                pStyle = pPr.makeelement(xml_utils.tag('pStyle'))
                pPr.append(pStyle)
            pStyle.set(xml_utils.tag('val'), "Normal")

            # Удаляем локальное форматирование прогонов
            for r in p.findall(xml_utils.tag('r')):
                rPr = r.find(xml_utils.tag('rPr'))
                if rPr is not None:
                    r.remove(rPr)

            modified += 1
        except Exception as e:
            log(f"  Ошибка при обработке абзаца #{idx}: {e}")

    log(f"Обработано абзацев: {modified}")
    log("<<< Применение единого стиля Normal завершено")
Что изменилось:

В функции setup_normal_style при создании/обновлении элемента spacing добавлена строка spacing.set(xml_utils.tag('after'), "0"). Это явно устанавливает интервал после абзаца в 0 для стиля Normal.

Также можно добавить before="0", если нужно, но обычно after основная проблема.

Теперь стиль Normal не будет добавлять лишний отступ после абзаца. Это должно решить проблему двойных интервалов и пустых листов.

Если у вас есть другие обработчики, которые могут добавлять after локально (например, в заголовках), нужно их тоже проверить. Но вы сказали, что after нигде не задаётся, так что этого должно быть достаточно.

