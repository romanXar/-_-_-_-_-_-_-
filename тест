# handlers/45_insert_visible_page_breaks.py
from utils import xml_utils
from lxml import etree
import re

def is_heading(p):
    """Проверяет, является ли абзац заголовком раздела (капс или нумерованный)."""
    text = xml_utils.get_paragraph_text(p).strip()
    if not text:
        return False
    if re.match(r'^\d+(\.\d+)*\s', text):
        return True
    has_upper = any(ch.isalpha() for ch in text)
    if not has_upper:
        return False
    return not any(ch.islower() for ch in text)

def is_structural_heading(text):
    """Проверяет, является ли заголовок регламентированным."""
    text_upper = text.strip().upper()
    if text_upper in ("РЕФЕРАТ", "СОДЕРЖАНИЕ", "ВВЕДЕНИЕ", "ЗАКЛЮЧЕНИЕ",
                      "СПИСОК СОКРАЩЕНИЙ", "СПИСОК ИСПОЛЬЗОВАННЫХ ИСТОЧНИКОВ"):
        return True
    if text_upper.startswith("ПРИЛОЖЕНИЕ"):
        return True
    if re.match(r'^\d+(\.\d+)*\s', text):
        return True
    return False

def is_numbered_heading(text):
    return re.match(r'^\d+(\.\d+)*\s', text) is not None

def is_empty_paragraph(p):
    """Проверяет, является ли абзац пустым (нет текста, рисунков, таблиц)."""
    if xml_utils.get_paragraph_text(p).strip():
        return False
    if xml_utils.has_drawing(p):
        return False
    if xml_utils.has_table(p):
        return False
    return True

def add_page_break_to_paragraph(p):
    """Добавляет символ разрыва страницы в существующий пустой абзац."""
    r = p.find(xml_utils.tag('r'))
    if r is None:
        r = etree.SubElement(p, xml_utils.tag('r'))
    br = etree.SubElement(r, xml_utils.tag('br'))
    br.set(xml_utils.tag('type'), 'page')

def create_page_break_paragraph():
    """Создаёт пустой абзац с символом разрыва страницы."""
    p = etree.Element(xml_utils.tag('p'))
    r = etree.SubElement(p, xml_utils.tag('r'))
    br = etree.SubElement(r, xml_utils.tag('br'))
    br.set(xml_utils.tag('type'), 'page')
    return p

def process(doc_root, styles_root=None, log=print):
    log(">>> Вставка разрывов страниц перед регламентированными разделами (с использованием существующих пустых абзацев)")

    paragraphs = xml_utils.find_all_paragraphs(doc_root)
    if not paragraphs:
        log("  Нет абзацев")
        return

    # Собираем все заголовки
    headers = []
    for i, p in enumerate(paragraphs):
        text = xml_utils.get_paragraph_text(p).strip()
        if text and is_heading(p):
            headers.append({
                'index': i,
                'text': text,
                'structural': is_structural_heading(text),
                'numbered': is_numbered_heading(text)
            })

    if not headers:
        log("  Не найдено заголовков")
        return

    log(f"  Найдено заголовков: {len(headers)}")

    modified = 0
    # Проходим по заголовкам, кроме первого
    for j in range(1, len(headers)):
        current = headers[j]
        prev = headers[j-1]

        # Если предыдущий заголовок не структурный — пропускаем
        if not prev['structural']:
            continue

        # Определяем, нужен ли разрыв между предыдущим и текущим
        need_break = True
        # Если оба нумерованные (внутри основной части) — разрыв не нужен
        if prev['numbered'] and current['numbered']:
            need_break = False

        if not need_break:
            log(f"  Пропуск (внутри основной части) между '{prev['text'][:30]}...' и '{current['text'][:30]}...'")
            continue

        # Ищем позицию для вставки разрыва: это позиция перед текущим заголовком
        target_idx = current['index']

        # Проверяем, есть ли непосредственно перед заголовком пустой абзац
        if target_idx > 0:
            prev_p = paragraphs[target_idx - 1]
            if is_empty_paragraph(prev_p):
                # Используем существующий пустой абзац
                # Проверяем, нет ли уже в нём разрыва
                if prev_p.find(f'.//{xml_utils.tag("br")}[@{xml_utils.tag("type")}="page"]') is None:
                    add_page_break_to_paragraph(prev_p)
                    modified += 1
                    log(f"  Разрыв добавлен в существующий пустой абзац перед '{current['text'][:30]}...'")
                else:
                    log(f"  Пропуск (разрыв уже есть) перед '{current['text'][:30]}...'")
                continue

        # Если пустого абзаца нет, создаём новый с разрывом
        parent = paragraphs[target_idx].getparent()
        pos = parent.index(paragraphs[target_idx])
        # Проверяем, нет ли уже разрыва (например, если предыдущий элемент — наш разрыв)
        if pos > 0:
            prev_elem = parent[pos-1]
            if prev_elem.find(f'.//{xml_utils.tag("br")}[@{xml_utils.tag("type")}="page"]') is not None:
                log(f"  Пропуск (разрыв уже есть) перед '{current['text'][:30]}...'")
                continue

        break_para = create_page_break_paragraph()
        parent.insert(pos, break_para)
        modified += 1
        log(f"  Создан новый абзац с разрывом перед '{current['text'][:30]}...'")

    log(f"  Разрывов добавлено/использовано: {modified}")
    log("<<< Вставка разрывов страниц завершена")
