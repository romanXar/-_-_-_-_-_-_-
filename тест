python
# handlers/40_final_formatting.py
import re
from lxml import etree
from utils import xml_utils

# Пространство имён для математики
MATH_NS = 'http://schemas.openxmlformats.org/officeDocument/2006/math'
NSMAP = {'w': xml_utils.NAMESPACE, 'm': MATH_NS}

def is_math_paragraph(p):
    if p.find('.//m:oMath', namespaces=NSMAP) is not None:
        return True
    if p.find('.//m:oMathPara', namespaces=NSMAP) is not None:
        return True
    return False

FIRST_LINE_INDENT_TWIPS = 709  # 1.25 см

def is_structural_heading(text):
    if len(text) < 3:
        return False
    return text.isupper() and not text.isdigit()

def is_table_title(text):
    return text.lower().startswith('таблица')

def is_figure_caption(text):
    return text.lower().startswith('рисунок')

def is_heading(text):
    return re.match(r'^\d+(\.\d+)*\s', text) is not None

def is_list_item(text):
    return re.match(r'^\d+\.\s', text) is not None

def ensure_bold_in_runs(p):
    for r in p.findall(xml_utils.tag('r')):
        rPr = r.find(xml_utils.tag('rPr'))
        if rPr is None:
            rPr = etree.SubElement(r, xml_utils.tag('rPr'))
        b = rPr.find(xml_utils.tag('b'))
        if b is None:
            etree.SubElement(rPr, xml_utils.tag('b'))

def create_heading_style(styles_root, log):
    if styles_root is None:
        log("  styles.xml не загружен, стиль не будет создан")
        return None
    for style in styles_root.findall(f'.//{xml_utils.tag("style")}'):
        style_id = style.get(xml_utils.tag('styleId'))
        if style_id == "HeadingSTU":
            log("  Стиль HeadingSTU уже существует")
            return style
    log("  Создание нового стиля HeadingSTU...")
    style = etree.SubElement(styles_root, xml_utils.tag('style'))
    style.set(xml_utils.tag('type'), "paragraph")
    style.set(xml_utils.tag('styleId'), "HeadingSTU")
    name = etree.SubElement(style, xml_utils.tag('name'))
    name.set(xml_utils.tag('val'), "HeadingSTU")
    basedOn = etree.SubElement(style, xml_utils.tag('basedOn'))
    basedOn.set(xml_utils.tag('val'), "Normal")
    rPr = etree.SubElement(style, xml_utils.tag('rPr'))
    b = etree.SubElement(rPr, xml_utils.tag('b'))
    rFonts = etree.SubElement(rPr, xml_utils.tag('rFonts'))
    rFonts.set(xml_utils.tag('ascii'), "Times New Roman")
    rFonts.set(xml_utils.tag('hAnsi'), "Times New Roman")
    rFonts.set(xml_utils.tag('cs'), "Times New Roman")
    sz = etree.SubElement(rPr, xml_utils.tag('sz'))
    sz.set(xml_utils.tag('val'), "28")
    szCs = etree.SubElement(rPr, xml_utils.tag('szCs'))
    szCs.set(xml_utils.tag('val'), "28")
    log("  Стиль HeadingSTU создан (Times New Roman 14, жирный)")
    return style

def process(doc_root, styles_root=None, log=print):
    log(">>> Финальное оформление по стандарту СТУ (с принудительным полуторным интервалом для заголовков)")

    heading_style = create_heading_style(styles_root, log)

    paragraphs = xml_utils.find_all_paragraphs(doc_root)
    title_end = xml_utils.find_title_end_index(paragraphs)
    if title_end > 0:
        log(f"Титульник заканчивается на абзаце #{title_end}, обрабатываем с #{title_end+1}")
    else:
        log("Титульник не найден, обрабатываем всё")
        title_end = 0

    modified = 0
    for idx, p in enumerate(paragraphs, 1):
        if idx <= title_end:
            continue
        if xml_utils.is_inside_table(p):
            continue

        # Удаляем локальное форматирование прогонов (чтобы не мешало)
        for r in p.findall(xml_utils.tag('r')):
            rPr = r.find(xml_utils.tag('rPr'))
            if rPr is not None:
                r.remove(rPr)

        text = xml_utils.get_paragraph_text(p).strip()
        has_drawing = xml_utils.has_drawing(p)

        log(f"  Абзац #{idx}: текст='{text[:60]}...'")

        # 1. Рисунки
        if has_drawing:
            xml_utils.set_paragraph_alignment(p, 'center')
            xml_utils.set_paragraph_indent(p, 0, 0, 0)
            modified += 1
            log(f"    -> рисунок: выравнивание по центру")
            continue

        # 2. Подписи рисунков
        if is_figure_caption(text):
            xml_utils.set_paragraph_alignment(p, 'center')
            xml_utils.set_paragraph_indent(p, 0, 0, 0)
            modified += 1
            log(f"    -> подпись рисунка: по центру")
            continue

        # 3. Названия таблиц
        if is_table_title(text):
            xml_utils.set_paragraph_alignment(p, 'left')
            xml_utils.set_paragraph_indent(p, 0, 0, 0)
            modified += 1
            log(f"    -> название таблицы: слева")
            continue

        # 4. Структурные заголовки (капсом)
        if is_structural_heading(text):
            # Получаем или создаём pPr
            pPr = p.find(xml_utils.tag('pPr'))
            if pPr is None:
                pPr = etree.SubElement(p, xml_utils.tag('pPr'))

            # Удаляем старый межстрочный интервал, если был
            old_spacing = pPr.find(xml_utils.tag('spacing'))
            if old_spacing is not None:
                pPr.remove(old_spacing)

            # Добавляем полуторный интервал явно
            spacing = etree.SubElement(pPr, xml_utils.tag('spacing'))
            spacing.set(xml_utils.tag('line'), '360')
            spacing.set(xml_utils.tag('lineRule'), 'auto')

            # --- Уровень структуры для TOC ---
            outlineLvl = pPr.find(xml_utils.tag('outlineLvl'))
            if outlineLvl is None:
                outlineLvl = etree.SubElement(pPr, xml_utils.tag('outlineLvl'))
            outlineLvl.set(xml_utils.tag('val'), '0')  # уровень 1

            # --- ДОБАВЛЕНО: не отрывать от следующего абзаца ---
            keepNext = etree.SubElement(pPr, xml_utils.tag('keepNext'))

            # Применяем стиль
            if heading_style is not None:
                pStyle = pPr.find(xml_utils.tag('pStyle'))
                if pStyle is None:
                    pStyle = etree.SubElement(pPr, xml_utils.tag('pStyle'))
                pStyle.set(xml_utils.tag('val'), "HeadingSTU")
            else:
                ensure_bold_in_runs(p)

            xml_utils.set_paragraph_alignment(p, 'center')
            xml_utils.set_paragraph_indent(p, 0, 0, 0)
            modified += 1
            log(f"    -> структурный заголовок (капс): жирный, по центру, полуторный интервал, уровень 1")
            continue

        # 5. Нумерованные заголовки
        if is_heading(text):
            pPr = p.find(xml_utils.tag('pPr'))
            if pPr is None:
                pPr = etree.SubElement(p, xml_utils.tag('pPr'))

            old_spacing = pPr.find(xml_utils.tag('spacing'))
            if old_spacing is not None:
                pPr.remove(old_spacing)

            spacing = etree.SubElement(pPr, xml_utils.tag('spacing'))
            spacing.set(xml_utils.tag('line'), '360')
            spacing.set(xml_utils.tag('lineRule'), 'auto')

            # --- Уровень структуры для TOC ---
            match = re.match(r'^(\d+(\.\d+)*)', text)
            if match:
                num_part = match.group(1)
                level = num_part.count('.')  # количество точек даёт уровень (0 для 1, 1 для 1.1, 2 для 1.1.1 и т.д.)
                outline_val = str(level)
            else:
                outline_val = '0'

            outlineLvl = pPr.find(xml_utils.tag('outlineLvl'))
            if outlineLvl is None:
                outlineLvl = etree.SubElement(pPr, xml_utils.tag('outlineLvl'))
            outlineLvl.set(xml_utils.tag('val'), outline_val)

            # --- ДОБАВЛЕНО: не отрывать от следующего абзаца ---
            keepNext = etree.SubElement(pPr, xml_utils.tag('keepNext'))

            if heading_style is not None:
                pStyle = pPr.find(xml_utils.tag('pStyle'))
                if pStyle is None:
                    pStyle = etree.SubElement(pPr, xml_utils.tag('pStyle'))
                pStyle.set(xml_utils.tag('val'), "HeadingSTU")
            else:
                ensure_bold_in_runs(p)

            xml_utils.set_paragraph_alignment(p, 'both')
            xml_utils.set_paragraph_indent(p, FIRST_LINE_INDENT_TWIPS, 0, 0)
            modified += 1
            log(f"    -> нумерованный заголовок: жирный, отступ {FIRST_LINE_INDENT_TWIPS}, полуторный интервал, уровень {outline_val}")
            continue

        # 6. Элементы списков
        if is_list_item(text):
            xml_utils.set_paragraph_alignment(p, 'both')
            xml_utils.set_paragraph_indent(p, FIRST_LINE_INDENT_TWIPS, 0, 0)
            modified += 1
            log(f"    -> элемент списка: отступ {FIRST_LINE_INDENT_TWIPS} twips")
            continue

        # 7. Формулы – без отступа, слева, с правой табуляцией
        if is_math_paragraph(p):
            xml_utils.set_paragraph_alignment(p, 'left')
            xml_utils.set_paragraph_indent(p, 0, 0, 0)
            xml_utils.ensure_right_tab(p, 9000)
            modified += 1
            log(f"    -> формула: по левому краю, правая табуляция")
            continue

        # 8. Обычный текст
        xml_utils.set_paragraph_alignment(p, 'both')
        xml_utils.set_paragraph_indent(p, FIRST_LINE_INDENT_TWIPS, 0, 0)
        modified += 1
        log(f"    -> обычный текст: отступ {FIRST_LINE_INDENT_TWIPS} twips")

    log(f"Обработано абзацев: {modified}")
    log("<<< Финальное оформление завершено")
Что изменилось:

В блоке структурных заголовков (капсом) после outlineLvl добавлен элемент <w:keepNext/>.

В блоке нумерованных заголовков после outlineLvl также добавлен <w:keepNext/>.

Теперь каждый заголовок будет автоматически удерживаться на одной странице со следующим за ним абзацем текста, что предотвращает ситуацию «заголовок внизу страницы, а текст на следующей».

еще остались места где нет переноса на новую строку. возможно это изза наличия пустых строк после заголовков
Мы получили сообщение пользователя: "еще остались места где нет переноса на новую строку. возможно это изза наличия пустых строк после заголовков". Это продолжение обсуждения проблемы висячих заголовков (когда заголовок остаётся внизу страницы, а текст на следующей). Ранее мы добавили в обработчик 40_final_formatting тег <w:keepNext/> для заголовков, чтобы Word автоматически переносил их на следующую страницу вместе с текстом. Но пользователь замечает, что в некоторых местах это не срабатывает, и предполагает, что причина в пустых строках после заголовков.

Действительно, если после заголовка идёт пустой абзац (пустая строка), то <w:keepNext/> привязывает заголовок к этому пустому абзацу, а не к тексту. Тогда заголовок всё ещё может остаться внизу, а пустая строка перейдёт на следующую страницу вместе с заголовком, но текст останется на предыдущей? На самом деле логика Word: keepNext обеспечивает, чтобы текущий абзац и следующий за ним были на одной странице. Если следующий абзац пустой, то они вместе переносятся на следующую страницу (если не помещаются), что может быть нежелательно: заголовок оказывается на следующей странице с пустой строкой, а текст после пустой строки может начаться позже.

Проблема: вставка пустых строк после заголовков (обработчик 41_insert_empty_lines) создаёт пустой абзац после заголовка. Этот пустой абзац становится "следующим" для заголовка, и keepNext связывает заголовок с пустым абзацем. Тогда заголовок и пустая строка будут вместе переноситься, но текст, идущий после пустой строки, может остаться отдельно. Это может привести к тому, что заголовок остаётся на странице с пустой строкой, а текст на новой странице (или наоборот). Чтобы заголовок привязывался именно к тексту, нужно либо не ставить keepNext на заголовок, либо вставлять пустую строку не отдельным абзацем, а как отступ внутри самого заголовка (например, через интервал после). Но по стандарту СТУ после заголовка должна быть пустая строка, но тогда keepNext не будет работать как ожидается, если мы хотим, чтобы заголовок не отрывался от первого абзаца текста.

Варианты решения:

Убрать keepNext с заголовков и полагаться на то, что Word сам не будет отрывать заголовок от текста, если интервал после заголовка задан как отступ (но это не гарантия).

Оставить keepNext, но сделать так, чтобы пустая строка после заголовка не была отдельным абзацем, а была реализована как интервал после в свойствах абзаца (w:spacing w:after). Тогда следующий абзац (текст) останется связанным с заголовком.

Если мы хотим оставить пустые строки как отдельные абзацы (для удобства редактирования), то можно в обработчике keepNext нацеливаться не на заголовок, а на пустой абзац после заголовка? Но тогда пустой абзац должен быть связан с текстом.

Сейчас обработчик 41_insert_empty_lines вставляет пустые абзацы после заголовков (в том числе после нумерованных и структурных). Это сделано для обеспечения отступов. Но с точки зрения keepNext это неправильно. Лучше было бы устанавливать интервал после заголовка (w:after) вместо вставки отдельного пустого абзаца. Однако стандарт СТУ явно говорит: "Заголовки отделяют от текста интервалом в одну строку". Можно интерпретировать это как пустую строку (отдельный абзац) или как увеличенный интервал после заголовка. В типографской практике обычно используют интервал после, а не пустой абзац. В Word интервал после задаётся в свойствах абзаца.

Таким образом, чтобы решить проблему висячих заголовков, нужно:

В обработчике 40_final_formatting добавить заголовкам интервал после (например, 240 twips = 12 pt, что соответствует высоте пустой строки) вместо вставки отдельного пустого абзаца.

Соответственно, в обработчике 41_insert_empty_lines убрать вставку пустых абзацев после заголовков, оставив только перед заголовками и после формул/подписей.

В обработчике 42_remove_extra_empty_paragraphs нужно будет учесть, что после заголовков уже нет пустых абзацев.

