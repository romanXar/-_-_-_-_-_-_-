В обработчике 45_insert_visible_page_breaks.py:

Определяем первый абзац документа (или первый абзац с текстом).

Для каждого регламентированного структурного элемента (список СТУ, включая СОДЕРЖАНИЕ), если он не является первым абзацем, вставляем перед ним видимый разрыв страницы.

Разрыв вставляется только один раз перед элементом (проверка на дубликат).

python
# handlers/45_insert_visible_page_breaks.py
from utils import xml_utils
from lxml import etree

def is_structural_element(text):
    """Проверяет, является ли текст регламентированным структурным элементом (все, включая СОДЕРЖАНИЕ)."""
    text_upper = text.strip().upper()
    # Полный список по СТУ
    if text_upper in ("РЕФЕРАТ", "СОДЕРЖАНИЕ", "ВВЕДЕНИЕ", "ЗАКЛЮЧЕНИЕ", 
                       "СПИСОК СОКРАЩЕНИЙ", "СПИСОК ИСПОЛЬЗОВАННЫХ ИСТОЧНИКОВ"):
        return True
    if text_upper.startswith("ПРИЛОЖЕНИЕ"):
        return True
    return False

def create_page_break_paragraph():
    """Создаёт пустой абзац с символом разрыва страницы."""
    p = etree.Element(xml_utils.tag('p'))
    r = etree.SubElement(p, xml_utils.tag('r'))
    br = etree.SubElement(r, xml_utils.tag('br'))
    br.set(xml_utils.tag('type'), 'page')
    return p

def process(doc_root, styles_root=None, log=print):
    log(">>> Вставка видимых разрывов страниц перед структурными элементами (кроме самого первого)")

    paragraphs = xml_utils.find_all_paragraphs(doc_root)
    if not paragraphs:
        log("  Нет абзацев")
        return

    # Находим первый абзац с текстом (или просто первый абзац, если все пустые)
    first_text_idx = None
    for i, p in enumerate(paragraphs):
        text = xml_utils.get_paragraph_text(p).strip()
        if text:
            first_text_idx = i
            break
    if first_text_idx is None:
        log("  В документе нет текста")
        return

    log(f"  Первый абзац с текстом на позиции {first_text_idx}")

    # Проходим по всем абзацам
    modified = 0
    # Идём с конца, чтобы не сбить индексы при вставке
    for i in range(len(paragraphs)-1, -1, -1):
        p = paragraphs[i]
        text = xml_utils.get_paragraph_text(p).strip()
        if not text or not is_structural_element(text):
            continue

        # Если это первый абзац с текстом - пропускаем
        if i == first_text_idx:
            log(f"  Пропуск (первый абзац): '{text[:30]}...'")
            continue

        parent = p.getparent()
        idx = parent.index(p)

        # Проверяем, нет ли уже разрыва перед этим абзацем
        if idx > 0:
            prev = parent[idx - 1]
            if prev.find(f'.//{xml_utils.tag("br")}[@{xml_utils.tag("type")}="page"]') is not None:
                log(f"  Пропуск (разрыв уже есть) перед: '{text[:30]}...'")
                continue

        # Вставляем разрыв
        break_para = create_page_break_paragraph()
        parent.insert(idx, break_para)
        modified += 1
        log(f"  Вставлен разрыв перед: '{text[:30]}...'")

    log(f"  Разрывов добавлено: {modified}")
    log("<<< Вставка видимых разрывов страниц завершена")
🔍 Что теперь происходит
Разрыв вставляется перед каждым структурным элементом (РЕФЕРАТ, СОДЕРЖАНИЕ, ВВЕДЕНИЕ, ЗАКЛЮЧЕНИЕ, СПИСОК СОКРАЩЕНИЙ, СПИСОК ИСПОЛЬЗОВАННЫХ ИСТОЧНИКОВ, ПРИЛОЖЕНИЕ), кроме самого первого абзаца с текстом (который обычно является темой работы).

Если перед структурным элементом уже есть разрыв (например, от предыдущего запуска), новый не добавляется.

Все разрывы видимы в Word (при включённом ¶) как пунктирная линия с надписью «Разрыв страницы», и их можно вручную удалить или переместить.

