python
# handlers/45_insert_visible_page_breaks.py
from utils import xml_utils
from lxml import etree

def is_structural_element(text):
    """Проверяет, является ли текст заголовком структурного элемента (кроме СОДЕРЖАНИЕ)."""
    text_upper = text.strip().upper()
    # Исключаем "СОДЕРЖАНИЕ" по вашей просьбе
    if text_upper in ("РЕФЕРАТ", "ВВЕДЕНИЕ", "ЗАКЛЮЧЕНИЕ", 
                       "СПИСОК СОКРАЩЕНИЙ", "СПИСОК ИСПОЛЬЗОВАННЫХ ИСТОЧНИКОВ"):
        return True
    if text_upper.startswith("ПРИЛОЖЕНИЕ"):
        return True
    return False

def create_page_break_paragraph():
    """Создаёт пустой абзац с символом разрыва страницы."""
    p = etree.Element(xml_utils.tag('p'))
    r = etree.SubElement(p, xml_utils.tag('r'))
    br = etree.SubElement(r, xml_utils.tag('br'))
    br.set(xml_utils.tag('type'), 'page')
    return p

def process(doc_root, styles_root=None, log=print):
    log(">>> Вставка видимых разрывов страниц ПОСЛЕ предыдущих структурных элементов")

    paragraphs = xml_utils.find_all_paragraphs(doc_root)
    if not paragraphs:
        log("  Нет абзацев")
        return

    # Собираем индексы абзацев, которые являются заголовками структурных элементов
    struct_indices = []
    for i, p in enumerate(paragraphs):
        text = xml_utils.get_paragraph_text(p).strip()
        if text and is_structural_element(text):
            struct_indices.append(i)

    if not struct_indices:
        log("  Нет структурных элементов")
        return

    log(f"  Найдены структурные элементы на позициях: {struct_indices}")

    modified = 0
    # Вставляем разрывы после предыдущего элемента для всех, кроме первого
    for idx in struct_indices[1:]:
        # Берём абзац текущего структурного элемента
        current_p = paragraphs[idx]
        parent = current_p.getparent()
        current_pos = parent.index(current_p)

        # Ищем предыдущий абзац, который не является структурным и не пуст? 
        # Проще: вставляем разрыв сразу перед текущим, но после всех пустых абзацев?
        # Но мы хотим вставить разрыв после предыдущего структурного элемента,
        # то есть где-то между предыдущим заголовком и текущим.

        # Найдём позицию, куда вставить разрыв – это позиция непосредственно перед текущим
        insert_pos = current_pos

        # Проверим, нет ли уже разрыва перед текущим
        if insert_pos > 0:
            prev = parent[insert_pos - 1]
            if prev.find(f'.//{xml_utils.tag("br")}[@{xml_utils.tag("type")}="page"]') is not None:
                log(f"  Пропуск: разрыв уже есть перед '{text[:30]}...'")
                continue

        # Вставляем разрыв
        break_para = create_page_break_paragraph()
        parent.insert(insert_pos, break_para)
        modified += 1
        text = xml_utils.get_paragraph_text(current_p).strip()
        log(f"  Вставлен разрыв перед '{text[:30]}...'")

    log(f"  Разрывов добавлено: {modified}")
    log("<<< Вставка видимых разрывов страниц завершена")
